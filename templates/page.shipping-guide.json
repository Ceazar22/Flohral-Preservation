      "blocks": {
        "step_4DNQeb": {
          "type": "step",
          "settings": {
            "step_label": "Step 1: Keep Flowers Cool at All Times",
            "text": "<p>Store your bouquet in the coolest environment available.</p><p>Keep it out of sunlight and away from heat or humidity.</p>"
          }
        },
        "step_QaC7Mp": {
          "type": "step",
          "settings": {
            "step_label": "Step 2: Use the Refrigerator (Safely)",
            "text": "<p>Refrigerator storage is ideal to help preserve freshness.</p><p>Do not place flowers near the freezer vent or in freezing temperatures.</p>"
          }
        },
        "step_bwrdrh": {
          "type": "step",
          "settings": {
            "step_label": "Step 3: Vase Storage for Short-Term Holding",
            "text": "<p>If you are shipping within 24 hours, you may keep the bouquet upright in a clean vase with a small amount of water.</p><p>Place it in a cool room, away from windows, heaters, or warm kitchen areas.</p>"
          }
        },
        "step_qLdQJW": {
          "type": "step",
          "settings": {
            "step_label": "Step 4: Avoid Freezing Temperatures",
            "text": "<p>Never place flowers in the freezer.</p><p>Freezing can damage petals and cause discoloration or brittleness.</p>"
          }
        },
        "step_TKRdpa": {
          "type": "step",
          "settings": {
            "step_label": "Step 5: Avoid Heat and Humidity",
            "text": "<p>Do not leave flowers in a hot car, steamy bathroom, or direct sunlight.</p><p>Heat and moisture accelerate damage.</p>"
          }
        }
      },
