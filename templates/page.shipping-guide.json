    "custom_faq_Shipping_Q7vN1c": {
      "type": "custom-faq",
      "blocks": {
        "faq_sh_01": {
          "type": "faq",
          "settings": {
            "question": "Who is responsible for tracking the bouquet shipment?",
            "answer": "<p>You are responsible for tracking your bouquet shipment and notifying us once it has been delivered to our studio.</p>"
          }
        },
        "faq_sh_02": {
          "type": "faq",
          "settings": {
            "question": "What happens if my bouquet is lost or damaged in transit?",
            "answer": "<p>Flohral Preservation is not responsible for flowers lost or damaged during shipping. If replacement flowers are required, they may be sourced for an additional charge depending on flower type and availability.</p>"
          }
        },
        "faq_sh_03": {
          "type": "faq",
          "settings": {
            "question": "Do all keepsakes get shipped?",
            "answer": "<p>Yes. Finished resin keepsakes are shipped for a standard <strong>$20 shipping fee</strong>, which may vary depending on size and item type.</p>"
          }
        },
        "faq_sh_04": {
          "type": "faq",
          "settings": {
            "question": "What are your shipping options and rules?",
            "answer": "<p>We ship within approved service areas using standard carriers. Shipping costs are based on item size, weight, and destination.</p>"
          }
        },
        "faq_sh_05": {
          "type": "faq",
          "settings": {
            "question": "Do you offer pickup for certain items?",
            "answer": "<p>Pickup is available by appointment. Contact us at <a href=\"mailto:floralpres@gmail.com\">floralpres@gmail.com</a> or <a href=\"tel:+18452901072\">(845) 290-1072</a> to schedule. Large items, like tables, are pickup only.</p>"
          }
        },
        "faq_sh_06": {
          "type": "faq",
          "settings": {
            "question": "Do you charge extra for express shipping or holiday deliveries?",
            "answer": "<p>Yes. Express shipping and holiday deliveries incur additional fees due to carrier surcharges and priority handling. All additional costs are confirmed prior to shipping.</p>"
          }
        },
        "faq_sh_07": {
          "type": "faq",
          "settings": {
            "question": "What happens if I provide the wrong shipping address?",
            "answer": "<p>Customers are responsible for providing accurate shipping information. If an incorrect address is submitted, additional fees may apply for rerouting or reshipping. We are not responsible for delays or losses caused by incorrect address details.</p>"
          }
        }
      },
      "block_order": [
