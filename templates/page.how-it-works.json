    "custom_faq_HowItWorks_9pT3aQ": {
      "type": "custom-faq",
      "blocks": {
        "faq_hw_01": {
          "type": "faq",
          "settings": {
            "question": "What is the first step to secure my preservation order?",
            "answer": "<p>A <strong>$150 deposit</strong> is required to reserve your spot on our preservation schedule. This secures your order and allows us to prepare for your bouquet. The remaining balance is due before your finished piece ships.</p>"
          }
        },
        "faq_hw_02": {
          "type": "faq",
          "settings": {
            "question": "How long will my preservation take?",
            "answer": "<p>Turnaround is typically <strong>6–8 months</strong> from the date your deposit is received. This timeline reflects the careful drying, design, and multi-stage resin curing process.</p>"
          }
        },
        "faq_hw_03": {
          "type": "faq",
          "settings": {
            "question": "Does engraving affect turnaround time?",
            "answer": "<p>Yes. Optional high-precision laser engraving may add up to one additional month to the overall turnaround time. Engraving is available for an additional <strong>$99</strong>, which includes up to two lines of text. Final engraving details must be confirmed before production continues to avoid delays.</p>"
          }
        },
        "faq_hw_04": {
          "type": "faq",
          "settings": {
            "question": "Does finalizing my order affect timing?",
            "answer": "<p>Yes. Finalizing your order promptly helps keep your piece within the expected timeline once your bouquet arrives. Delays in decisions can extend completion.</p>"
          }
        },
        "faq_hw_05": {
          "type": "faq",
          "settings": {
            "question": "How do I approve my design layout?",
            "answer": "<p>Once your flowers are ready, Debbie will email a custom layout for your approval. You may approve it as-is or request small adjustments such as flower placement or balance.</p>"
          }
        },
        "faq_hw_06": {
          "type": "faq",
          "settings": {
            "question": "Is there a deadline for layout approval?",
            "answer": "<p>Yes. We ask that approvals or feedback be provided promptly. Delayed responses can slow production and extend the overall turnaround time.</p>"
          }
        },
        "faq_hw_07": {
          "type": "faq",
          "settings": {
            "question": "Can I revise the layout after it’s sent?",
            "answer": "<p>Absolutely. Minor adjustments are included. Changes to shape, size, or product type are possible as long as they match or upgrade your original order. Additional fees may apply depending on the request.</p>"
          }
        },
        "faq_hw_08": {
          "type": "faq",
          "settings": {
            "question": "What happens if I request last-minute changes?",
            "answer": "<p>We’ll always review your request, but once preservation or resin curing has begun, changes may be limited or no longer possible. We will clearly communicate what can and cannot be adjusted at that stage.</p>"
          }
        },
        "faq_hw_09": {
          "type": "faq",
          "settings": {
            "question": "Do add-ons like candles or ring holders receive a layout?",
            "answer": "<p>No. Smaller add-on items are artistically filled with flowers and do not require a design layout approval.</p>"
          }
        },
        "faq_hw_10": {
          "type": "faq",
          "settings": {
            "question": "What if my flowers are not enough for the piece I selected?",
            "answer": "<p>If your bouquet does not provide enough usable flowers for the selected piece, we will supplement or replace flowers as needed to complete your design. This may involve an additional charge depending on the type and quantity of flowers required.</p><p>We strongly recommend contacting us as soon as possible if you believe your bouquet may be limited. Please email us or call our studio directly so we can discuss options before production continues.</p>"
          }
        },
        "faq_hw_11": {
          "type": "faq",
          "settings": {
            "question": "When will my finished piece ship?",
            "answer": "<p>Your piece will ship after full payment is received. You’ll receive a USPS tracking number once it leaves our studio.</p>"
          }
        },
        "faq_hw_12": {
          "type": "faq",
          "settings": {
            "question": "Can I return my order?",
            "answer": "<p>All orders are non-refundable due to the custom and sentimental nature of preservation. That said, if you’re not completely happy, we’ll work with you to find a reasonable solution.</p>"
          }
        },
        "faq_hw_13": {
          "type": "faq",
          "settings": {
            "question": "Will I receive care instructions?",
            "answer": "<p>Yes. Every piece includes a care card with instructions to help protect your keepsake long-term.</p>"
          }
        },
        "faq_hw_14": {
          "type": "faq",
          "settings": {
            "question": "Can I add items after placing my order?",
            "answer": "<p>Yes. Simply call or email us and we’ll let you know what can be added based on your project’s current stage.</p>"
          }
        }
      },
