    "custom_faq_KKcLmV": {
      "type": "custom-faq",
      "blocks": {
        "faq_w3AFqC": {
          "type": "faq",
          "settings": {
            "question": "How does flower preservation work?",
            "answer": "<p>Your flowers are carefully dried, artistically arranged, and preserved in resin through a multi-stage process. Each piece is made by hand and cured over time to create a lasting keepsake that honors your memories.</p>"
          }
        },
        "faq_nBtHp9": {
          "type": "faq",
          "settings": {
            "question": "How long does the preservation process take?",
            "answer": "<p>Turnaround is typically <strong>6–8 months</strong> from the time your deposit is received. This timeline reflects the detailed drying and resin curing process required for long-lasting results.</p>"
          }
        },
        "faq_i6pYnk": {
          "type": "faq",
          "settings": {
            "question": "When do I pay and how do I secure my order?",
            "answer": "<p>A <strong>$150 deposit</strong> secures your spot in our floral preservation schedule and reserves your place in our calendar because we only have a limited number of spots in each month.</p>"
          }
        },
        "faq_jWEVbQ": {
          "type": "faq",
          "settings": {
            "question": "Can I approve or customize the design?",
            "answer": "<p>Yes. You’ll receive a custom layout for approval before resin work begins. Small adjustments are welcome, and upgrades or changes may be made depending on your order.</p>"
          }
        },
        "faq_DA8q6W": {
          "type": "faq",
          "settings": {
            "question": "Do you ship nationwide?",
            "answer": "<p>Yes. We work with clients nationwide and ship finished resin keepsakes using trusted carriers. Shipping fees vary based on item size and destination.</p>"
          }
        }
      },
      "block_order": [
        "faq_w3AFqC",
