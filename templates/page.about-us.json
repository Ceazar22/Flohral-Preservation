    "custom_faq_AboutUs_K2dR8m": {
      "type": "custom-faq",
      "blocks": {
        "faq_au_01": {
          "type": "faq",
          "settings": {
            "question": "Where are you based and who do you work with?",
            "answer": "<p>We are based in New York and work with clients nationwide. Our pieces preserve flowers from weddings, memorials, anniversaries, and life milestones across the U.S.</p>"
          }
        },
        "faq_au_02": {
          "type": "faq",
          "settings": {
            "question": "What makes you different from other preservation studios?",
            "answer": "<p>Experience and honesty. We bring over two decades of hands-on resin work, custom techniques, and transparent communication. We don’t promise perfection. We promise craftsmanship, realism, and care for irreplaceable flowers.</p>"
          }
        },
        "faq_au_03": {
          "type": "faq",
          "settings": {
            "question": "Why do customers choose to work with you long-term?",
            "answer": "<p>Because we set clear expectations, deliver consistent quality, and treat every bouquet as one-of-a-kind. Many clients return for future milestones or refer family and friends because trust is built over time.</p>"
          }
        },
        "faq_au_04": {
          "type": "faq",
          "settings": {
            "question": "What can customers expect when working with you for the first time?",
            "answer": "<p>A guided process, clear timelines, realistic outcomes, and personal communication directly from our studio. You’ll always know what to expect before, during, and after preservation.</p>"
          }
        }
      },
      "block_order": [
        "faq_au_01",
        "faq_au_02",
        "faq_au_03",
        "faq_au_04"
      ],
