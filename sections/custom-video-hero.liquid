{%- style -%}
  #shopify-section-{{ section.id }}{
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;

    --h-desktop: {{ section.settings.height_desktop }}px;
    --h-mobile: {{ section.settings.height_mobile }}px;

    --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --overlay: {{ section.settings.overlay_color.red }}, {{ section.settings.overlay_color.green }}, {{ section.settings.overlay_color.blue }};

    --text: {{ section.settings.text_color.red }}, {{ section.settings.text_color.green }}, {{ section.settings.text_color.blue }};

    --btn-bg: {{ section.settings.button_bg.red }}, {{ section.settings.button_bg.green }}, {{ section.settings.button_bg.blue }};
    --btn-text: {{ section.settings.button_text.red }}, {{ section.settings.button_text.green }}, {{ section.settings.button_text.blue }};

    /* Bottom strip */
    --strip-bg: {{ section.settings.strip_bg.red }}, {{ section.settings.strip_bg.green }}, {{ section.settings.strip_bg.blue }};
    --strip-text: {{ section.settings.strip_text.red }}, {{ section.settings.strip_text.green }}, {{ section.settings.strip_text.blue }};
    --strip-pad-y: {{ section.settings.strip_padding_y }}px;
    --strip-side-pad: {{ section.settings.strip_side_padding }}px;
  }
{%- endstyle -%}

<style>
  #shopify-section-{{ section.id }} .video-hero{
    position: relative;
    width: 100%;
    height: var(--h-desktop);
    overflow: hidden;
    background: #000;
  }

  #shopify-section-{{ section.id }} .video-hero__media{
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  /* Media elements fill container */
  #shopify-section-{{ section.id }} .video-hero__media video,
  #shopify-section-{{ section.id }} .video-hero__media iframe,
  #shopify-section-{{ section.id }} .video-hero__media img{
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Hide native controls if browser still shows them */
  #shopify-section-{{ section.id }} .video-hero__media video::-webkit-media-controls{
    display: none !important;
  }

  #shopify-section-{{ section.id }} .video-hero::before{
    content:"";
    position:absolute;
    inset:0;
    z-index: 1;
    background: rgb(var(--overlay));
    opacity: var(--overlay-opacity);
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .video-hero__content{
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: var(--pt);
    padding-bottom: var(--pb);
  }

  #shopify-section-{{ section.id }} .video-hero__inner{
    width: 100%;
    max-width: 980px;
    text-align: {{ section.settings.text_align }};
    color: rgb(var(--text));
  }

  #shopify-section-{{ section.id }} .video-hero__heading{
    margin: 0;
    font-weight: 800;
    line-height: 1.05;
    color: rgb(var(--text));
    font-size: clamp(32px, 4.2vw, 54px);
  }

  #shopify-section-{{ section.id }} .video-hero__subheading{
    margin: 12px 0 0;
    color: rgb(var(--text));
    opacity: .92;
    font-size: clamp(14px, 1.8vw, 20px);
    line-height: 1.4;
  }

  #shopify-section-{{ section.id }} .video-hero__btn-wrap{
    margin-top: 22px;
    display: flex;
    justify-content: center;
  }
  #shopify-section-{{ section.id }} .video-hero__btn-wrap.align-left{ justify-content: flex-start; }
  #shopify-section-{{ section.id }} .video-hero__btn-wrap.align-right{ justify-content: flex-end; }

  #shopify-section-{{ section.id }} .video-hero__btn{
    display: inline-block;
    padding: 14px 26px;
    border-radius: 2px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: .16em;
    font-size: 12px;
    font-weight: 800;
    background: rgb(var(--btn-bg));
    color: rgb(var(--btn-text));
  }
  #shopify-section-{{ section.id }} .video-hero__btn:hover{
    filter: brightness(.96);
  }

  /* ✅ Optional bottom strip */
  #shopify-section-{{ section.id }} .video-hero__strip{
    width: 100%;
    background: rgb(var(--strip-bg));
    color: rgb(var(--strip-text));
  }

  #shopify-section-{{ section.id }} .video-hero__strip-inner{
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--strip-pad-y) var(--strip-side-pad);
    text-transform: uppercase;
    letter-spacing: .14em;
    font-size: 11px;
    font-weight: 800;
  }

  #shopify-section-{{ section.id }} .video-hero__strip-item{
    flex: 1 1 0;
    text-align: center;
    padding: 0 18px;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .video-hero__strip.has-dividers .video-hero__strip-item + .video-hero__strip-item{
    border-left: 1px solid rgba(var(--strip-text), .35);
  }

  @media (max-width: 749px){
    #shopify-section-{{ section.id }} .video-hero{
      height: var(--h-mobile);
    }
    #shopify-section-{{ section.id }} .video-hero__inner{
      max-width: 92%;
    }

    #shopify-section-{{ section.id }} .video-hero__strip-inner{
      flex-direction: column;
      gap: 0;
      padding: var(--strip-pad-y) 16px;
    }
    #shopify-section-{{ section.id }} .video-hero__strip-item{
      width: 100%;
      padding: 10px 0;
      white-space: normal;
    }
    #shopify-section-{{ section.id }} .video-hero__strip.has-dividers .video-hero__strip-item + .video-hero__strip-item{
      border-left: 0;
      border-top: 1px solid rgba(var(--strip-text), .35);
    }
  }
</style>

<div class="video-hero">
  <div class="video-hero__media" aria-hidden="true">
    {%- if section.settings.media_type == 'image' -%}
      {%- if section.settings.hero_image != blank -%}
        {{ section.settings.hero_image | image_url: width: 2400 | image_tag: loading: 'lazy' }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}

    {%- else -%}
      {%- if section.settings.video != blank -%}
        {{ section.settings.video
          | video_tag:
            autoplay: true,
            loop: section.settings.loop_video,
            muted: section.settings.mute_video,
            controls: false,
            playsinline: true
        }}
      {%- elsif section.settings.video_url != blank -%}
        {%- liquid
          assign v = section.settings.video_url
          assign vid = v.id
          assign type = v.type
        -%}

        {%- if type == 'youtube' -%}
          <iframe
            src="https://www.youtube.com/embed/{{ vid }}?autoplay=1&mute=1&controls=0&playsinline=1&rel=0&modestbranding=1&loop=1&playlist={{ vid }}"
            title="Background video"
            frameborder="0"
            allow="autoplay; encrypted-media; picture-in-picture"
            allowfullscreen
          ></iframe>
        {%- elsif type == 'vimeo' -%}
          <iframe
            src="https://player.vimeo.com/video/{{ vid }}?autoplay=1&muted=1&background=1&loop=1&byline=0&title=0"
            title="Background video"
            frameborder="0"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
          ></iframe>
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    {%- endif -%}
  </div>

  <div class="video-hero__content {% unless section.settings.content_full_width %}page-width{% endunless %}">
    <div class="video-hero__inner">
      <{{ section.settings.heading_tag }} class="video-hero__heading">
        {%- if section.settings.enable_highlight -%}
          {%- render 'highlight-text',
            hl_input: section.settings.heading,
            hl_style: section.settings.highlight_style,
            hl_enable: true,
            hl_animateWrap: true -%}
        {%- else -%}
          {{ section.settings.heading }}
        {%- endif -%}
      </{{ section.settings.heading_tag }}>

      {%- if section.settings.subheading != blank -%}
        <div class="video-hero__subheading">
          {{ section.settings.subheading }}
        </div>
      {%- endif -%}

      {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
        <div class="video-hero__btn-wrap {% if section.settings.text_align == 'left' %}align-left{% elsif section.settings.text_align == 'right' %}align-right{% endif %}">
          <a class="video-hero__btn" href="{{ section.settings.button_link }}">
            {{ section.settings.button_label }}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{%- if section.settings.strip_enable -%}
  <div class="video-hero__strip {% if section.settings.strip_dividers %}has-dividers{% endif %}">
    <div class="video-hero__strip-inner {% unless section.settings.content_full_width %}page-width{% endunless %}">
      {%- if section.settings.strip_item_1 != blank -%}<div class="video-hero__strip-item">{{ section.settings.strip_item_1 }}</div>{%- endif -%}
      {%- if section.settings.strip_item_2 != blank -%}<div class="video-hero__strip-item">{{ section.settings.strip_item_2 }}</div>{%- endif -%}
      {%- if section.settings.strip_item_3 != blank -%}<div class="video-hero__strip-item">{{ section.settings.strip_item_3 }}</div>{%- endif -%}
      {%- if section.settings.strip_item_4 != blank -%}<div class="video-hero__strip-item">{{ section.settings.strip_item_4 }}</div>{%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Video hero (autoplay)",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "checkbox", "id": "content_full_width", "label": "Content full width (disable page-width)", "default": false },

    { "type": "header", "content": "Media" },
    {
      "type": "select",
      "id": "media_type",
      "label": "Media type",
      "default": "video",
      "options": [
        { "value": "video", "label": "Video" },
        { "value": "image", "label": "Image" }
      ]
    },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image (when Media type = Image)" },

    { "type": "header", "content": "Video" },
    { "type": "video", "id": "video", "label": "Shopify hosted video" },
    {
      "type": "video_url",
      "id": "video_url",
      "accept": ["youtube", "vimeo"],
      "label": "YouTube/Vimeo URL (fallback)",
      "info": "Autoplay usually requires mute on YouTube/Vimeo."
    },
    { "type": "checkbox", "id": "mute_video", "label": "Mute video (recommended for autoplay)", "default": true },
    { "type": "checkbox", "id": "loop_video", "label": "Loop video", "default": true },

    { "type": "header", "content": "Content" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Your bouquet is too special to lose" },
    { "type": "inline_richtext", "id": "subheading", "label": "Subheading", "default": "3-Easy Steps to Flohr-ever" },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "options": [
        { "value": "h1", "label": "h1" },
        { "value": "h2", "label": "h2" },
        { "value": "h3", "label": "h3" },
        { "value": "div", "label": "div" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },

    { "type": "text", "id": "button_label", "label": "Button label", "default": "RESERVE YOUR SPOT" },
    { "type": "url", "id": "button_link", "label": "Button link" },

    { "type": "header", "content": "Overlay" },
    { "type": "color", "id": "overlay_color", "label": "Overlay color", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity (%)", "min": 0, "max": 90, "step": 5, "default": 40 },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },
    { "type": "color", "id": "button_bg", "label": "Button background", "default": "#b23b5a" },
    { "type": "color", "id": "button_text", "label": "Button text", "default": "#ffffff" },

    { "type": "header", "content": "Size" },
    { "type": "range", "id": "height_desktop", "label": "Height desktop (px)", "min": 280, "max": 800, "step": 20, "default": 420 },
    { "type": "range", "id": "height_mobile", "label": "Height mobile (px)", "min": 220, "max": 600, "step": 20, "default": 300 },

    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 0 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 0 },

    { "type": "header", "content": "Bottom strip (optional)" },
    { "type": "checkbox", "id": "strip_enable", "label": "Show bottom strip", "default": false },
    { "type": "checkbox", "id": "strip_dividers", "label": "Show dividers", "default": true },
    { "type": "color", "id": "strip_bg", "label": "Strip background", "default": "#b23b5a" },
    { "type": "color", "id": "strip_text", "label": "Strip text color", "default": "#ffffff" },
    { "type": "range", "id": "strip_padding_y", "label": "Strip padding (px)", "min": 6, "max": 30, "step": 2, "default": 14 },
    { "type": "range", "id": "strip_side_padding", "label": "Side padding (px)", "min": 0, "max": 60, "step": 4, "default": 0 },
    { "type": "text", "id": "strip_item_1", "label": "Item 1", "default": "WOMAN OWNED AND OPERATED" },
    { "type": "text", "id": "strip_item_2", "label": "Item 2", "default": "TRUSTED BY TOP FLORISTS IN NEW YORK" },
    { "type": "text", "id": "strip_item_3", "label": "Item 3", "default": "LIMITED SPOTS EACH MONTH" },
    { "type": "text", "id": "strip_item_4", "label": "Item 4", "default": "VIP COMMUNICATION & CUSTOM SERVICE" },

    { "type": "header", "content": "Heading highlight (optional)" },
    { "type": "checkbox", "id": "enable_highlight", "label": "Enable highlight", "default": false },
    {
      "type": "select",
      "id": "highlight_style",
      "options": [
        { "value": "marker", "label": "Marker" },
        { "value": "circle", "label": "Circle" },
        { "value": "underline", "label": "Underline" },
        { "value": "bold-underline", "label": "Bold underline" },
        { "value": "modern-underline", "label": "Modern underline" },
        { "value": "sketch-underline", "label": "Sketch underline" },
        { "value": "squiggle", "label": "Squiggle" },
        { "value": "heavy-squiggle", "label": "Heavy squiggle" },
        { "value": "solid-color", "label": "Solid color" }
      ],
      "default": "marker",
      "label": "Highlight style"
    }
  ],
  "presets": [
    { "name": "Video hero (autoplay)" }
  ],
  "disabled_on": { "groups": ["header", "footer", "custom.overlay"] }
}
{% endschema %}
