{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- if section.settings.image != blank %}
      --image-ratio-percent: {{ 1 | divided_by: section.settings.image.aspect_ratio | times: 100 }}%;
      --image-position: {{ section.settings.image_position }};
    {% endif -%}
    --color-overlay-opacity: {{ section.settings.colors_overlay_opacity | divided_by: 100.0 }};
    --color-overlay: {{ section.settings.colors_overlay.red }}, {{ section.settings.colors_overlay.green }}, {{ section.settings.colors_overlay.blue }};
    --color-foreground: {{ section.settings.colors_text.red }}, {{ section.settings.colors_text.green }}, {{ section.settings.colors_text.blue }};
    --color-link: var(--color-foreground);
    --color-border: var(--color-foreground);

    /* NEW: heading color setting (section content headings) */
    --color-heading: {{ section.settings.colors_heading.red }}, {{ section.settings.colors_heading.green }}, {{ section.settings.colors_heading.blue }};

    --color-highlight: {{ section.settings.colors_highlight.red }}, {{ section.settings.colors_highlight.green }}, {{ section.settings.colors_highlight.blue }};

    /* NEW: bullet color for custom list style */
    --px-bullet: {{ section.settings.list_bullet_color.red }}, {{ section.settings.list_bullet_color.green }}, {{ section.settings.list_bullet_color.blue }};
  }

  {%- if section.settings.image_mobile != blank and section.settings.mobile_image_ratio == 'adapt' %}
    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} {
        --image-ratio-percent: {{ 1 | divided_by: section.settings.image_mobile.aspect_ratio | times: 100 }}%;
      }
    }  
  {% endif -%}
{%- endstyle -%}

{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}
{{ 'section-reveal-banner.css' | asset_url | stylesheet_tag }}

<link rel="stylesheet" href="{{ 'component-deferred-media.css' | asset_url }}" media="print" onload="this.media='all'">

<style>
  .reveal-slide__video {
    margin-top: 1rem;
    max-width: 520px;
  }

  .reveal-slide__video-embed {
    position: relative;
    width: 100%;
    padding-top: 56.25%;
    overflow: hidden;
    border-radius: 12px;
  }

  .reveal-slide__video-embed iframe,
  .reveal-slide__video-embed video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    object-fit: cover;
  }

  .banner__box.center .reveal-slide__video { margin-left: auto; margin-right: auto; }
  .banner__box.right .reveal-slide__video { margin-left: auto; }

  /* ===== NEW: Custom list style like your design ===== */
  #shopify-section-{{ section.id }}.px-list--flower .rte ul {
    list-style: none;
    padding-left: 0;
    margin-left: 0;
  }
  #shopify-section-{{ section.id }}.px-list--flower .rte li {
    position: relative;
    padding-left: 22px;
    margin: 0 0 10px 0;
  }
  #shopify-section-{{ section.id }}.px-list--flower .rte li::before {
    content: "";
    width: 12px;
    height: 12px;
    position: absolute;
    left: 0;
    top: 0.45em;
    background-color: rgb(var(--px-bullet));

    /* 8-point floral/star */
    -webkit-mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path d='M12 2l1.4 6 5.6-2.6-2.6 5.6 6 1.4-6 1.4 2.6 5.6-5.6-2.6L12 22l-1.4-6-5.6 2.6 2.6-5.6L2 12l6-1.4L5.4 5l5.6 2.6L12 2z'/></svg>") center/contain no-repeat;
    mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path d='M12 2l1.4 6 5.6-2.6-2.6 5.6 6 1.4-6 1.4 2.6 5.6-5.6-2.6L12 22l-1.4-6-5.6 2.6 2.6-5.6L2 12l6-1.4L5.4 5l5.6 2.6L12 2z'/></svg>") center/contain no-repeat;
  }

  /* ===== NEW: Slide subheading style ===== */
  #shopify-section-{{ section.id }} .reveal-slide__subheading{
    margin: 0 0 10px;
    letter-spacing: .14em;
    text-transform: uppercase;
    font-weight: 800;
  }

  /* ===== NEW: Slide corner image (bottom-right) ===== */
  #shopify-section-{{ section.id }} .banner__slide .banner__box {
    position: relative;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .reveal-slide__corner {
    position: absolute;
    right: 0;
    bottom: 0;
    width: var(--corner-w, 180px);
    opacity: var(--corner-opacity, 0.35);
    transform: translate(18%, 18%);
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .reveal-slide__corner img {
    width: 100%;
    height: auto;
    display: block;
  }
</style>

{%- assign reveal = section.blocks | where: "type", "slide" | first -%}

<div
  id="shopify-section-{{ section.id }}"
  class="section--padding{% if section.settings.show_divider %} section--divider{% endif %}{% if section.settings.list_style == 'flower' %} px-list--flower{% endif %}"
>
  <div class="banner-wrapper page-width{% if section.settings.full_width %} page-width--full-width{% endif %}">
    {%- if reveal -%}
      <animate-sticky data-trigger-offset="0.65" data-reset-offset="0.85"></animate-sticky>
    {%- endif -%}

    <div id="Banner-{{ section.id }}" class="banner--reveal{% if section.settings.image != blank %} banner--stacked{% endif %}{% if section.settings.show_text_below %} banner--mobile-bottom{% endif %}">
      <use-animate>
        <div class="banner__media">
          <div class="media-wrapper">
            <div class="media media--{{ section.settings.image_ratio }} media-mobile--{{ section.settings.mobile_image_ratio }}">
              {%- if section.settings.image != blank -%}
                {%- capture sizes -%}{% if section.settings.full_width %}100vw{% else %}(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 }}px, (min-width: 750px) calc(100vw - 10rem), calc(100vw - 3rem){% endif %}{%- endcapture -%}
                {%- liquid
                  if section.settings.image_mobile == blank
                    echo section.settings.image | image_url: width: 3840 | image_tag: loading: 'lazy', class: 'image-fit', sizes: sizes, widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840', is: 'lazy-image'
                  else
                    echo section.settings.image | image_url: width: 3840 | image_tag: loading: 'lazy', class: 'image-fit small-hide', sizes: sizes, widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840', is: 'lazy-image'
                    echo section.settings.image_mobile | image_url: width: 3840 | image_tag: loading: 'lazy', class: 'image-fit medium-hide large-up-hide', sizes: sizes, widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840', is: 'lazy-image'
                  endif
                -%}
              {%- else -%}
                {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder image-animate' }}
              {%- endif -%}
            </div>
          </div>
        </div>

        {%- if section.blocks.size > 0 -%}
          <div class="banner__content {{ section.settings.text_box_position }} page-width">
            <div class="banner__box {{ section.settings.text_alignment }} mobile-{{ section.settings.mobile_text_alignment }}">
              {%- for block in section.blocks -%}
                {%- case block.type -%}
                  {%- when 'heading' -%}
                    <{{ block.settings.heading_tag }} class="banner__heading {{ block.settings.heading_size }}" data-animate {{ block.shopify_attributes }}>
                      {%- render 'highlight-text', 
                        hl_input: block.settings.heading, 
                        hl_style: block.settings.highlight_style,
                        hl_enable: block.settings.enable_highlight,
                        hl_animateWrap: true -%}
                    </{{ block.settings.heading_tag }}>

                  {%- when 'subheading' -%}
                    <p class="banner__subheading{% if block.settings.secondary_color %} banner__subheading--colored{% endif %} {{ block.settings.subheading_size }}" data-animate {{ block.shopify_attributes }}>
                      {%- render 'highlight-text', 
                        hl_input: block.settings.subheading, 
                        hl_style: block.settings.highlight_style,
                        hl_enable: block.settings.enable_highlight,
                        hl_animateWrap: true -%}
                    </p>

                  {%- when 'text' -%}
                    <div class="banner__text{% if block.settings.secondary_color %} banner__text--colored{% endif %} {{ block.settings.text_size }} rte" data-animate {{ block.shopify_attributes }}>
                      {%- render 'highlight-text', 
                        hl_input: block.settings.text, 
                        hl_style: block.settings.highlight_style,
                        hl_enable: block.settings.enable_highlight,
                        hl_animateWrap: true -%}
                    </div>

                  {%- when 'custom_liquid' -%}
                    <div class="banner__text rte" {{ block.shopify_attributes }}>
                      {{ block.settings.custom_liquid }}
                    </div>

                  {%- when 'buttons' -%}
                    <div class="banner__buttons" data-animate {{ block.shopify_attributes }}>
                      {%- if block.settings.button_label != blank -%}
                        <p>
                          <a class="button button--cta"{% if block.settings.button_link != blank %} href="{{ block.settings.button_link }}"{% else %} role="link" aria-disabled="true"{% endif %}>
                            <span class="label">{{ block.settings.button_label | escape }}</span>
                            {% render 'icon', icon: 'arrow' %}
                          </a>
                        </p>
                      {%- endif -%}

                      {%- if block.settings.video_button != blank -%}
                        <noscript>
                          <p>
                            <a class="button button--cta button--video"{% if block.settings.video_url != blank %} href="{{ block.settings.video_url }}"{% else %} role="link" aria-disabled="true"{% endif %}>
                              <span class="label">{{ block.settings.video_button | escape }}</span>
                              {% render 'icon', icon: 'play-circle' %}
                            </a>
                          </p>
                        </noscript>

                        <modal-opener class="no-js-hidden" data-modal="#PopupModal-{{ block.id }}">
                          <button type="button" class="button button--cta button--video"{% if block.settings.video_url == blank %} aria-disabled="true"{% endif %}>
                            <span class="label">{{ block.settings.video_button | escape }}</span>
                            {% render 'icon', icon: 'play-circle' %}
                          </button>
                        </modal-opener>

                        {%- capture modal_dialog -%}
                          <modal-dialog id="PopupModal-{{ block.id }}" class="banner-video__modal">
                            <div class="banner-video__modal-content" role="dialog" aria-label="{{ block.settings.video_description | escape }}" aria-modal="true" tabindex="-1">
                              <button id="ModalClose-{{ block.id }}" type="button" class="banner-video__modal-toggle" aria-label="{{ 'accessibility.close' | t }}">
                                {% render 'icon', icon: 'close' %}
                              </button>
                              <deferred-media class="banner-video__modal-video template-popup">
                                <template>
                                  {%- if block.settings.video_url.type == 'youtube' -%}
                                    <iframe src="https://www.youtube.com/embed/{{ block.settings.video_url.id }}?enablejsapi=1" class="js-youtube" allow="autoplay; encrypted-media" allowfullscreen title="{{ block.settings.video_description | escape }}"></iframe>
                                  {%- else -%}
                                    <iframe src="https://player.vimeo.com/video/{{ block.settings.video_url.id }}" class="js-vimeo" allow="autoplay; encrypted-media" allowfullscreen title="{{ block.settings.video_description | escape }}"></iframe>
                                  {%- endif -%}
                                </template>
                              </deferred-media>
                            </div>
                          </modal-dialog>
                        {%- endcapture -%}
                      {%- endif -%}
                    </div>
                {%- endcase -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      </use-animate>

      {%- if reveal -%}
        <div class="banner__slide page-width" {{ reveal.shopify_attributes }}>
          {%- style -%}
            #shopify-section-{{ section.id }} .banner__slide {
              --gradient-background: #fff8fb;
              --color-background: 255, 248, 251;
              --color-foreground: {{ reveal.settings.colors_text.red }}, {{ reveal.settings.colors_text.green }}, {{ reveal.settings.colors_text.blue }};
              --color-link: var(--color-foreground);
              --color-border: var(--color-foreground);

              /* NEW: slide heading color */
              --color-heading: {{ reveal.settings.colors_heading.red }}, {{ reveal.settings.colors_heading.green }}, {{ reveal.settings.colors_heading.blue }};

              --color-button-background: {{ reveal.settings.colors_button_background.red }}, {{ reveal.settings.colors_button_background.green }}, {{ reveal.settings.colors_button_background.blue }};
              --color-button-text: {{ reveal.settings.colors_button_label.red }}, {{ reveal.settings.colors_button_label.green }}, {{ reveal.settings.colors_button_label.blue }};
              --color-button-border: var(--color-button-background);
              --color-shadow: var(--color-foreground);
              --shadow-opacity: 0.3;

              background: #fff8fb !important;
              background-color: #fff8fb !important;
            }
          {%- endstyle -%}

          <div class="banner__box {{ section.settings.text_alignment }} mobile-{{ section.settings.mobile_text_alignment }}">

            {%- if reveal.settings.slide_subheading != blank -%}
              <p class="reveal-slide__subheading {{ reveal.settings.slide_subheading_size }}">
                {{ reveal.settings.slide_subheading }}
              </p>
            {%- endif -%}

            <{{ reveal.settings.heading_tag }} class="banner__heading {{ reveal.settings.heading_size }}">
              {%- render 'highlight-text', 
                hl_input: reveal.settings.heading, 
                hl_style: reveal.settings.highlight_style,
                hl_enable: reveal.settings.enable_highlight,
                hl_animateWrap: true -%}
            </{{ reveal.settings.heading_tag }}>

            <div class="banner__text{% if reveal.settings.secondary_color %} banner__text--colored{% endif %} {{ reveal.settings.text_size }} rte">
              {%- render 'highlight-text', 
                hl_input: reveal.settings.text, 
                hl_style: reveal.settings.highlight_style,
                hl_enable: reveal.settings.enable_highlight,
                hl_animateWrap: true -%}
            </div>

            {%- if reveal.settings.show_slide_video and reveal.settings.slide_video != blank or reveal.settings.show_slide_video and reveal.settings.slide_video_url != blank -%}
              <div class="reveal-slide__video">
                <div class="reveal-slide__video-embed">
                  {%- if reveal.settings.slide_video != blank -%}
                    {{ reveal.settings.slide_video
                      | video_tag:
                        image_size: '1200x',
                        autoplay: true,
                        loop: true,
                        muted: true,
                        controls: false,
                        playsinline: true,
                        class: 'reveal-slide__video-native'
                    }}
                  {%- elsif reveal.settings.slide_video_url != blank -%}
                    {%- if reveal.settings.slide_video_url.type == 'youtube' -%}
                      <iframe
                        src="https://www.youtube.com/embed/{{ reveal.settings.slide_video_url.id }}?rel=0&modestbranding=1"
                        allow="autoplay; encrypted-media"
                        allowfullscreen
                        title="{{ reveal.settings.slide_video_description | escape }}"></iframe>
                    {%- else -%}
                      <iframe
                        src="https://player.vimeo.com/video/{{ reveal.settings.slide_video_url.id }}"
                        allow="autoplay; encrypted-media"
                        allowfullscreen
                        title="{{ reveal.settings.slide_video_description | escape }}"></iframe>
                    {%- endif -%}
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}

            {%- if reveal.settings.button_label != blank -%}
              {%- if reveal.settings.button_style_secondary -%}
                <a class="button button--cta button--{{ reveal.settings.button_size }}"{% if reveal.settings.button_link != blank %} href="{{ reveal.settings.button_link }}"{% else %} role="link" aria-disabled="true"{% endif %}>
                  <span class="label">{{ reveal.settings.button_label | escape }}</span>
                  {% render 'icon', icon: 'arrow' %}
                </a>
              {%- else -%}
                <a class="button button--{{ reveal.settings.button_size }}"{% if reveal.settings.button_link != blank %} href="{{ reveal.settings.button_link }}"{% else %} role="link" aria-disabled="true"{% endif %}>
                  {{ reveal.settings.button_label | escape }}
                </a>
              {%- endif -%}
            {%- endif -%}

            {%- if reveal.settings.corner_image != blank -%}
              <div
                class="reveal-slide__corner{% if reveal.settings.corner_hide_mobile %} small-hide{% endif %}"
                style="--corner-w: {{ reveal.settings.corner_width }}px; --corner-opacity: {{ reveal.settings.corner_opacity | divided_by: 100.0 }};"
                aria-hidden="true"
              >
                <img
                  src="{{ reveal.settings.corner_image | image_url: width: 800 }}"
                  alt=""
                  loading="lazy"
                  width="{{ reveal.settings.corner_image.width }}"
                  height="{{ reveal.settings.corner_image.height }}"
                >
              </div>
            {%- endif -%}

          </div>
        </div>
      {%- endif -%}
    </div>

    {{ modal_dialog }}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.reveal-banner.name",
  "tag": "section",
  "class": "section banner-section--reveal",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "t:sections.all.image.label" },

    {
      "type": "select",
      "id": "image_position",
      "options": [
        { "value": "20% 0", "label": "t:sections.all.image_position.options__1.label" },
        { "value": "top center", "label": "t:sections.all.image_position.options__2.label" },
        { "value": "80% 0", "label": "t:sections.all.image_position.options__3.label" },
        { "value": "20% 50%", "label": "t:sections.all.image_position.options__4.label" },
        { "value": "center center", "label": "t:sections.all.image_position.options__5.label" },
        { "value": "80% 50%", "label": "t:sections.all.image_position.options__6.label" },
        { "value": "20% 100%", "label": "t:sections.all.image_position.options__7.label" },
        { "value": "bottom center", "label": "t:sections.all.image_position.options__8.label" },
        { "value": "80% 100%", "label": "t:sections.all.image_position.options__9.label" }
      ],
      "default": "center center",
      "label": "t:sections.all.image_position.label",
      "info": "t:sections.all.image_position.info"
    },

    {
      "type": "select",
      "id": "text_box_position",
      "options": [
        { "value": "top", "label": "t:sections.reveal-banner.settings.text_box_position.options__1.label" },
        { "value": "middle", "label": "t:sections.reveal-banner.settings.text_box_position.options__2.label" },
        { "value": "bottom", "label": "t:sections.reveal-banner.settings.text_box_position.options__3.label" }
      ],
      "default": "middle",
      "label": "t:sections.reveal-banner.settings.text_box_position.label"
    },

    {
      "type": "select",
      "id": "text_alignment",
      "options": [
        { "value": "left", "label": "t:sections.all.text_alignment.options__1.label" },
        { "value": "center", "label": "t:sections.all.text_alignment.options__2.label" },
        { "value": "right", "label": "t:sections.all.text_alignment.options__3.label" }
      ],
      "default": "left",
      "label": "t:sections.all.text_alignment.label"
    },

    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        { "label": "t:sections.all.image_ratio.options__1.label", "value": "adapt" },
        { "label": "t:sections.all.image_ratio.options__2.label", "value": "400px" },
        { "label": "t:sections.all.image_ratio.options__3.label", "value": "450px" },
        { "label": "t:sections.all.image_ratio.options__4.label", "value": "500px" },
        { "label": "t:sections.all.image_ratio.options__5.label", "value": "550px" },
        { "label": "t:sections.all.image_ratio.options__6.label", "value": "600px" },
        { "label": "t:sections.all.image_ratio.options__7.label", "value": "650px" },
        { "label": "t:sections.all.image_ratio.options__8.label", "value": "700px" },
        { "label": "t:sections.all.image_ratio.options__9.label", "value": "750px" },
        { "label": "t:sections.all.image_ratio.options__10.label", "value": "100vh" }
      ],
      "default": "650px",
      "label": "t:sections.all.image_ratio.label"
    },

    { "type": "checkbox", "id": "full_width", "default": true, "label": "t:sections.all.full_width.label" },
    { "type": "checkbox", "id": "show_divider", "default": false, "label": "t:sections.all.show_divider.label" },

    { "type": "header", "content": "t:sections.all.mobile_layout.header.content" },
    { "type": "image_picker", "id": "image_mobile", "label": "t:sections.all.image_mobile.label" },

    {
      "type": "select",
      "id": "mobile_text_alignment",
      "options": [
        { "value": "left", "label": "t:sections.all.mobile_layout.mobile_text_alignment.options__1.label" },
        { "value": "center", "label": "t:sections.all.mobile_layout.mobile_text_alignment.options__2.label" },
        { "value": "right", "label": "t:sections.all.mobile_layout.mobile_text_alignment.options__3.label" }
      ],
      "default": "center",
      "label": "t:sections.all.mobile_layout.mobile_text_alignment.label"
    },

    {
      "type": "select",
      "id": "mobile_image_ratio",
      "options": [
        { "label": "t:sections.all.mobile_layout.mobile_image_ratio.options__1.label", "value": "auto" },
        { "label": "t:sections.all.mobile_layout.mobile_image_ratio.options__2.label", "value": "200px" },
        { "label": "t:sections.all.mobile_layout.mobile_image_ratio.options__3.label", "value": "250px" },
        { "label": "t:sections.all.mobile_layout.mobile_image_ratio.options__4.label", "value": "300px" },
        { "label": "t:sections.all.mobile_layout.mobile_image_ratio.options__5.label", "value": "400px" },
        { "label": "t:sections.all.mobile_layout.mobile_image_ratio.options__6.label", "value": "500px" },
        { "label": "t:sections.all.mobile_layout.mobile_image_ratio.options__7.label", "value": "600px" },
        { "label": "t:sections.all.mobile_layout.mobile_image_ratio.options__8.label", "value": "100vh" },
        { "label": "t:sections.all.mobile_layout.mobile_image_ratio.options__9.label", "value": "adapt" }
      ],
      "default": "auto",
      "label": "t:sections.all.mobile_layout.mobile_image_ratio.label"
    },

    { "type": "checkbox", "id": "show_text_below", "default": false, "label": "t:sections.reveal-banner.settings.show_text_below.label" },

    { "type": "header", "content": "t:sections.all.colors.header.content" },
    { "type": "color", "id": "colors_text", "label": "t:sections.all.colors.colors_text.label", "default": "#ffffff" },

    { "type": "color", "id": "colors_heading", "label": "Heading color", "default": "#d84f7c" },

    { "type": "color", "id": "colors_overlay", "label": "t:sections.all.colors.colors_overlay.label", "default": "#000000" },

    {
      "type": "range",
      "id": "colors_overlay_opacity",
      "label": "t:sections.all.colors.overlay_opacity.label",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "t:sections.all.colors.overlay_opacity.unit"
    },

    { "type": "color", "id": "colors_highlight", "label": "t:sections.all.colors.colors_highlight.label", "default": "#ffb503" },

    {
      "type": "select",
      "id": "list_style",
      "label": "List style",
      "default": "default",
      "options": [
        { "value": "default", "label": "Default bullets" },
        { "value": "flower", "label": "Flower/star bullets" }
      ]
    },
