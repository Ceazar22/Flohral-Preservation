{%- style -%}
  #shopify-section-{{ section.id }}{
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;

    --overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --overlay-color: {{ section.settings.overlay_color.red }}, {{ section.settings.overlay_color.green }}, {{ section.settings.overlay_color.blue }};

    --title-color: {{ section.settings.title_color.red }}, {{ section.settings.title_color.green }}, {{ section.settings.title_color.blue }};
    --text-color: {{ section.settings.text_color.red }}, {{ section.settings.text_color.green }}, {{ section.settings.text_color.blue }};

    --btn-bg: {{ section.settings.button_bg }};
    --btn-text: {{ section.settings.button_text }};
    --btn-radius: {{ section.settings.button_radius }}px;
    --min-h: {{ section.settings.min_height }}px;
  }
{%- endstyle -%}

<style>
  #shopify-section-{{ section.id }} .cta-overlay{
    padding-top: var(--pt);
    padding-bottom: var(--pb);
  }

  #shopify-section-{{ section.id }} .cta-overlay__wrap{
    position: relative;
    width: 100%;
    min-height: var(--min-h);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .cta-overlay__bg{
    position: absolute;
    inset: 0;
    z-index: 0;
    background: #f3f3f3;
  }
  #shopify-section-{{ section.id }} .cta-overlay__bg img{
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .cta-overlay__bg::after{
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(var(--overlay-color), var(--overlay));
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .cta-overlay__inner{
    position: relative;
    z-index: 2;
    width: 100%;
    text-align: center;
    padding: 24px {{ section.settings.side_padding }}px;
  }

  #shopify-section-{{ section.id }} .cta-overlay__title{
    margin: 0;
    color: rgb(var(--title-color));
    font-weight: 700;
    line-height: 1.05;
    font-size: clamp(26px, 3.8vw, 44px);
  }

  #shopify-section-{{ section.id }} .cta-overlay__text{
    margin: 10px auto 0;
    max-width: 70ch;
    color: rgb(var(--text-color));
    opacity: .95;
    font-size: 18px;
    line-height: 1.6;
  }
  #shopify-section-{{ section.id }} .cta-overlay__text p{ margin: 0; }

  #shopify-section-{{ section.id }} .cta-overlay__cta{
    margin-top: 16px;
    display: flex;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .cta-overlay__btn{
    display: inline-block;
    padding: 12px 22px;
    background: var(--btn-bg);
    color: var(--btn-text);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: .16em;
    font-size: 12px;
    font-weight: 700;
    border-radius: var(--btn-radius);
  }
  #shopify-section-{{ section.id }} .cta-overlay__btn:hover{
    filter: brightness(.96);
  }
</style>

<section class="cta-overlay">
  <div class="{% unless section.settings.full_width %}page-width{% endunless %}">
    <div class="cta-overlay__wrap">
      <div class="cta-overlay__bg">
        {%- if section.settings.bg_image != blank -%}
          {{ section.settings.bg_image | image_url: width: 2400 | image_tag: loading: 'lazy', alt: section.settings.title }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

      <div class="cta-overlay__inner">
        <{{ section.settings.title_tag }} class="cta-overlay__title">
          {{ section.settings.title }}
        </{{ section.settings.title_tag }}>

        {%- if section.settings.text != blank -%}
          <div class="cta-overlay__text rte">
            {{ section.settings.text }}
          </div>
        {%- endif -%}

        {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
          <div class="cta-overlay__cta">
            <a class="cta-overlay__btn" href="{{ section.settings.button_link }}">
              {{ section.settings.button_label }}
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTA overlay banner",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "checkbox", "id": "full_width", "default": true, "label": "Full width" },

    { "type": "image_picker", "id": "bg_image", "label": "Background image" },
    { "type": "range", "id": "min_height", "label": "Minimum height (px)", "min": 160, "max": 520, "step": 10, "default": 240 },
    { "type": "range", "id": "side_padding", "label": "Side padding (px)", "min": 0, "max": 60, "step": 4, "default": 20 },

    { "type": "header", "content": "Text" },
    { "type": "text", "id": "title", "label": "Title", "default": "Have more questions?" },
    {
      "type": "select",
      "id": "title_tag",
      "label": "Title tag",
      "options": [
        { "value": "h1", "label": "h1" },
        { "value": "h2", "label": "h2" },
        { "value": "h3", "label": "h3" },
        { "value": "div", "label": "div" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Lorem ipsum dolor sit amet consectetur adipiscing elit rhoncus, augue inceptos dis ante nascetur quis nostra felis, tellus a erat.</p>"
    },

    { "type": "header", "content": "Overlay" },
    { "type": "color", "id": "overlay_color", "label": "Overlay color", "default": "#b23b5a" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity (%)", "min": 0, "max": 90, "step": 5, "default": 45 },

    { "type": "header", "content": "Button" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "CONTACT US" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "color", "id": "button_bg", "label": "Button background", "default": "#b23b5a" },
    { "type": "color", "id": "button_text", "label": "Button text", "default": "#ffffff" },
    { "type": "range", "id": "button_radius", "label": "Button radius (px)", "min": 0, "max": 20, "step": 2, "default": 2 },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "title_color", "label": "Title color", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 0 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 0 }
  ],
  "presets": [
    { "name": "CTA overlay banner" }
  ],
  "disabled_on": { "groups": ["header", "footer", "custom.overlay"] }
}
{% endschema %}
