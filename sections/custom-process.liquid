{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;

    --color-highlight: {{ section.settings.colors_highlight.red }}, {{ section.settings.colors_highlight.green }}, {{ section.settings.colors_highlight.blue }};
    --how-accent: {{ section.settings.accent_color.red }}, {{ section.settings.accent_color.green }}, {{ section.settings.accent_color.blue }};
    --how-connector: {{ section.settings.connector_color.red }}, {{ section.settings.connector_color.green }}, {{ section.settings.connector_color.blue }};

    --how-circle-size: {{ section.settings.circle_size }}px;

    --how-bg: {{ section.settings.bg_color }};
    --how-gap: {{ section.settings.connector_gap }}px;
  }

  #shopify-section-{{ section.id }} .section--padding {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
    background: var(--how-bg);
  }
{%- endstyle -%}

<style>
    #shopify-section-{{ section.id }} .how-it-works {
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .how-it-works {
    text-align: center;

    /* NEW: share one gap var between grid + connector math */
    --how-steps-gap: clamp(20px, 4vw, 60px);

    /*
      NEW: inset connector so it starts after circle 1 and ends before circle 3.
      ( (container - 2*gaps)/6 ) = center of first column in a 3-col grid
    */
    --how-connector-inset: calc(
      (100% - (2 * var(--how-steps-gap))) * 0.1666667 +
      (var(--how-circle-size) * 0.5) +
      var(--how-gap)
    );
  }

  /* Force eyebrow + heading to stack (some themes set title-wrapper to flex) */
  #shopify-section-{{ section.id }} .how-it-works .title-wrapper {
    display: block !important;
    width: 100%;
  }
  #shopify-section-{{ section.id }} .how-it-works .title-wrapper.left { text-align: left; }
  #shopify-section-{{ section.id }} .how-it-works .title-wrapper.center { text-align: center; }
  #shopify-section-{{ section.id }} .how-it-works .title-wrapper.right { text-align: right; }

  #shopify-section-{{ section.id }} .how-it-works__eyebrow {
    margin: 0 0 10px;
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.8;
    display: block;
    width: 100%;
    text-align: inherit;
  }

  /* NEW: heading color like your reference */
  #shopify-section-{{ section.id }} .how-it-works .title {
    color: rgb(var(--how-accent));
  }

  #shopify-section-{{ section.id }} .how-it-works__subheading {
    margin: 14px auto 0;
    max-width: 70ch;
    opacity: 0.85;
  }

  #shopify-section-{{ section.id }} .how-it-works__steps-wrap {
    position: relative;
    margin-top: 34px;
  }

  /* One continuous connector behind all steps */
  #shopify-section-{{ section.id }} .how-it-works__connector {
    position: absolute;
    left: var(--how-connector-inset);
    right: var(--how-connector-inset);

    height: 160px; /* CHANGED */
    top: calc((var(--how-circle-size) / 2) - 80px); /* CHANGED */

    z-index: 0;
    pointer-events: none;
  }


  #shopify-section-{{ section.id }} .how-it-works__connector path {
    vector-effect: non-scaling-stroke;
  }

  #shopify-section-{{ section.id }} .how-it-works__steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--how-steps-gap); /* CHANGED */
    align-items: start;
    position: relative;
    z-index: 1; /* steps above connector */
  }

  #shopify-section-{{ section.id }} .how-it-works__step {
    max-width: 360px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .how-it-works__icon-area {
    position: relative;
    width: var(--how-circle-size);
    margin: 0 auto;
  }

  /* HALO MASK: erases the connector around each circle */
  #shopify-section-{{ section.id }} .how-it-works__icon-area::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    /* was: (var(--how-gap) * 2) */
width: calc(var(--how-circle-size) + (var(--how-gap) * 1.2));
height: calc(var(--how-circle-size) + (var(--how-gap) * 1.2));

    border-radius: 999px;
    background: var(--how-bg);
    z-index: 1; /* above connector, below the circle */
  }

  #shopify-section-{{ section.id }} .how-it-works__icon-number {
    position: absolute;
    top: -6px;
    left: -10px;
    font-size: 14px;
    font-weight: 600;
    z-index: 3;
  }

  #shopify-section-{{ section.id }} .how-it-works__icon-circle {
    width: var(--how-circle-size);
    height: var(--how-circle-size);
    border-radius: 999px;

    /* CHANGED: neutral outline like reference */
    border: 2px solid rgb(var(--how-connector));

    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--how-bg);
    overflow: hidden;
    position: relative;
    z-index: 2; /* above halo */
  }

  #shopify-section-{{ section.id }} .how-it-works__icon-image {
    max-width: calc(var(--how-circle-size) * 0.55);
    max-height: calc(var(--how-circle-size) * 0.55);
    width: auto;
    height: auto;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .how-it-works__step-title {
    margin: 18px 0 8px;
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .how-it-works__step-text {
    margin: 0;
    opacity: 0.85;
  }

  #shopify-section-{{ section.id }} .how-it-works__cta-wrap {
    margin-top: 32px;
    display: flex;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .how-it-works__cta {
    display: inline-block;
    padding: 14px 26px;
    background: rgb(var(--how-accent));
    color: #fff;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 12px;
    font-weight: 700;
    border-radius: 2px;
  }

  #shopify-section-{{ section.id }} .how-it-works__cta:hover {
    filter: brightness(0.95);
  }

  @media (max-width: 989px) {
  #shopify-section-{{ section.id }} .how-it-works__steps {
    grid-template-columns: 1fr;
    gap: 28px;
  }

  #shopify-section-{{ section.id }} .how-it-works__connector {
    display: none;
  }

  #shopify-section-{{ section.id }} .how-it-works__icon-number {
    display: none;
  }

}
</style>

<div class="section--padding{% if section.settings.show_divider %} section--divider{% endif %}">
  <div class="how-it-works page-width">
    <div class="title-wrapper {{ section.settings.heading_alignment }}">
      {%- if section.settings.eyebrow != blank -%}
        <p class="how-it-works__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <{{ section.settings.heading_tag }} class="title {{ section.settings.heading_size }}">
        {%- render 'highlight-text',
          hl_input: section.settings.heading,
          hl_style: section.settings.highlight_style,
          hl_enable: section.settings.enable_highlight,
          hl_animateWrap: true -%}
      </{{ section.settings.heading_tag }}>

      {%- if section.settings.subheading != blank -%}
        <div class="how-it-works__subheading rte">
          {{ section.settings.subheading }}
        </div>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="how-it-works__steps-wrap">
        {%- if section.settings.show_connector and section.blocks.size == 3 -%}
          <svg class="how-it-works__connector" viewBox="0 0 1000 160" preserveAspectRatio="none" aria-hidden="true" focusable="false">
            <path
              d="M0 80
                Q 125 40 250 80
                Q 375 120 500 80
                Q 625 40 750 80
                Q 875 120 1000 80"
              fill="none"
              stroke="rgb(var(--how-connector))"
              stroke-width="3"
              stroke-linecap="round"
              stroke-dasharray="3 12"
              vector-effect="non-scaling-stroke" />

          </svg>
        {%- endif -%}

        <div class="how-it-works__steps">
          {%- for block in section.blocks -%}
            <div class="how-it-works__step" {{ block.shopify_attributes }}>
              <div class="how-it-works__icon-area">
                <div class="how-it-works__icon-number">{{ block.settings.step_number | default: forloop.index }}</div>

                <div class="how-it-works__icon-circle">
                  {%- if block.settings.icon != blank -%}
                    {{ block.settings.icon | image_url: width: 360 | image_tag: loading: 'lazy', class: 'how-it-works__icon-image' }}
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg how-it-works__icon-image' }}
                  {%- endif -%}
                </div>
              </div>

              <h3 class="how-it-works__step-title">
                {%- if section.settings.show_step_prefix -%}
                  {{ section.settings.step_prefix }} {{ block.settings.step_number | default: forloop.index }}:&nbsp;
                {%- endif -%}
                {{ block.settings.title }}
              </h3>

              {%- if block.settings.text != blank -%}
                <div class="how-it-works__step-text rte">
                  {{ block.settings.text }}
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
      <div class="how-it-works__cta-wrap">
        <a class="how-it-works__cta" href="{{ section.settings.button_link }}">
          {{ section.settings.button_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "How it works (Process)",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    { "type": "checkbox", "id": "show_divider", "default": false, "label": "Show divider" },
    { "type": "text", "id": "eyebrow", "default": "HOW IT WORKS", "label": "Eyebrow text" },
    { "type": "inline_richtext", "id": "heading", "default": "The Flohr-Ever Process", "label": "Heading" },
    { "type": "richtext", "id": "subheading", "label": "Subheading (optional)" },

    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        { "value": "h1", "label": "h1" },
        { "value": "h2", "label": "h2" },
        { "value": "h3", "label": "h3" },
        { "value": "div", "label": "div" },
        { "value": "p", "label": "p" }
      ],
      "default": "h2",
      "label": "Heading tag"
    },

    { "type": "header", "content": "Steps" },
    { "type": "checkbox", "id": "show_connector", "default": true, "label": "Show dashed connector (only shows when exactly 3 steps)" },
    { "type": "range", "id": "circle_size", "min": 90, "max": 200, "step": 5, "default": 150, "label": "Icon circle size (px)" },
    { "type": "checkbox", "id": "show_step_prefix", "default": true, "label": "Show “Step X:” prefix in title" },
    { "type": "text", "id": "step_prefix", "default": "Step", "label": "Step prefix text" },

    { "type": "header", "content": "Button" },
    { "type": "text", "id": "button_label", "default": "PRESERVE MY BOUQUET", "label": "Button label" },
    { "type": "url", "id": "button_link", "label": "Button link" },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Section background (for connector gap)", "default": "#ffffff" },
    { "type": "range", "id": "connector_gap", "min": 0, "max": 30, "step": 1, "default": 14, "label": "Connector gap around circles (px)" },
    { "type": "color", "id": "colors_highlight", "label": "Highlight color", "default": "#ffb503" },
    { "type": "color", "id": "accent_color", "label": "Accent (heading + button)", "default": "#a2435a" },
    { "type": "color", "id": "connector_color", "label": "Connector + circle outline", "default": "#d6d6d6" },

    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 48 },

    { "type": "header", "content": "Heading highlight (uses your theme snippet)" },
    { "type": "checkbox", "id": "enable_highlight", "label": "Enable highlight", "default": false },
    {
      "type": "select",
      "id": "highlight_style",
      "options": [
        { "value": "marker", "label": "Marker" },
        { "value": "circle", "label": "Circle" },
        { "value": "underline", "label": "Underline" },
        { "value": "bold-underline", "label": "Bold underline" },
        { "value": "modern-underline", "label": "Modern underline" },
        { "value": "sketch-underline", "label": "Sketch underline" },
        { "value": "squiggle", "label": "Squiggle" },
        { "value": "heavy-squiggle", "label": "Heavy squiggle" },
        { "value": "solid-color", "label": "Solid color" }
      ],
      "default": "marker",
      "label": "Highlight style"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "step_number", "label": "Step number (optional override)" },
        { "type": "image_picker", "id": "icon", "label": "Icon image" },
        { "type": "text", "id": "title", "default": "Reserve Your Spot", "label": "Title" },
        { "type": "richtext", "id": "text", "default": "<p>Add your step description here.</p>", "label": "Text" }
      ]
    }
  ],
  "presets": [
    {
      "name": "How it works (Process)",
      "blocks": [
        { "type": "step" },
        { "type": "step" },
        { "type": "step" }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer", "custom.overlay"]
  }
}
{% endschema %}
