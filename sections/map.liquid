{%- liquid
  assign ratio_percent = 56.25
  if section.settings.image != blank and section.settings.image.aspect_ratio
    assign ratio_percent = 1 | divided_by: section.settings.image.aspect_ratio | times: 100
  endif

  assign mobile_ratio = section.settings.mobile_image_ratio
  if mobile_ratio == 'auto'
    assign mobile_ratio = section.settings.image_ratio
  endif

  assign dest_encoded = section.settings.map_address | url_encode
-%}

{%- style -%}
  #shopify-section-{{ section.id }}{
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;

    --color-highlight: {{ section.settings.colors_highlight.red }}, {{ section.settings.colors_highlight.green }}, {{ section.settings.colors_highlight.blue }};

    --color-background-opacity: {{ section.settings.colors_overlay_opacity | divided_by: 100.0 }};
    --color-background: {{ section.settings.colors_overlay.red }}, {{ section.settings.colors_overlay.green }}, {{ section.settings.colors_overlay.blue }};
    --color-foreground: {{ section.settings.colors_text.red }}, {{ section.settings.colors_text.green }}, {{ section.settings.colors_text.blue }};
    --color-button-background: {{ section.settings.colors_button_background.red }}, {{ section.settings.colors_button_background.green }}, {{ section.settings.colors_button_background.blue }};
    --color-button-text: {{ section.settings.colors_button_label.red }}, {{ section.settings.colors_button_label.green }}, {{ section.settings.colors_button_label.blue }};

    --image-position: {{ section.settings.image_position }};
    --ratio-percent: {{ ratio_percent }}%;
  }
{%- endstyle -%}

{{ 'section-map.css' | asset_url | stylesheet_tag }}

<style>
  #shopify-section-{{ section.id }} .section--padding{
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
  }

  #shopify-section-{{ section.id }} .map-split{
    width: 100%;
  }

  #shopify-section-{{ section.id }} .map-split__header{
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    max-width: 760px;
    margin: 0 auto 24px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .map-split__header .eyebrow-heading__title{
    margin: 0 0 10px;
    width: 100%;
    text-align: center;
    color: rgb(var(--color-heading));
    line-height: 1.1;
    font-size: clamp(
      calc(var(--font-heading-scale) * 2.8rem),
      4vw,
      calc(var(--font-heading-scale) * 4rem)
    );
  }

  #shopify-section-{{ section.id }} .map-split__header-address{
    margin: 0 auto;
    width: 100%;
    text-align: center;
    color: rgb(var(--color-foreground));
  }

  #shopify-section-{{ section.id }} .map-split__header-address p{
    margin: 0;
  }

  #shopify-section-{{ section.id }} .map-split__header-hours-title{
    margin: 16px 0 8px;
    letter-spacing: .18em;
    text-transform: uppercase;
    font-size: 1.1rem;
    color: rgba(var(--color-foreground), .7);
  }

  #shopify-section-{{ section.id }} .map-split__header-hours{
    width: min(100%, 320px);
    margin: 0 auto;
    color: rgb(var(--color-foreground));
  }

  #shopify-section-{{ section.id }} .map-split__header-hours table{
    width: 100%;
    border-collapse: collapse;
    font-size: 1.3rem;
  }

  #shopify-section-{{ section.id }} .map-split__header-hours td{
    padding: 10px 12px;
    border: 1px solid rgba(var(--color-foreground), .12);
    text-align: left;
  }

  #shopify-section-{{ section.id }} .map-split__grid{
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  #shopify-section-{{ section.id }} .map-split__media{
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  {% if section.settings.image_ratio != 'adapt' %}
    #shopify-section-{{ section.id }} .map-split__media{
      height: {{ section.settings.image_ratio }};
    }
  {% else %}
    #shopify-section-{{ section.id }} .map-split__media{
      padding-bottom: var(--ratio-percent);
    }

    #shopify-section-{{ section.id }} .map-split__media > *{
      position: absolute;
      inset: 0;
    }
  {% endif %}

  #shopify-section-{{ section.id }} .map-split__map{
    position: relative;
  }

  /* Google Maps iframe fills the whole left side */
  #shopify-section-{{ section.id }} .px-google-map{
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    background: #f2f2f2;
  }

  /* Optional soft loading background behind iframe */
  #shopify-section-{{ section.id }} .px-google-map-shell{
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    background:
      radial-gradient(circle at 25% 30%, rgba(0,0,0,.06), transparent 55%),
      radial-gradient(circle at 70% 70%, rgba(0,0,0,.05), transparent 60%),
      linear-gradient(135deg, rgba(0,0,0,.04), rgba(0,0,0,.02));
  }

  #shopify-section-{{ section.id }} .map-split__card{
    position: absolute;
    z-index: 2;
    max-width: min(420px, 88%);
    background: rgba(var(--color-background), var(--color-background-opacity));
    color: rgb(var(--color-foreground));
    padding: 22px 22px;
    box-shadow: 0 12px 30px rgba(0,0,0,.18);
  }

  #shopify-section-{{ section.id }} .map-split__card--top-left{
    top: 22px;
    left: 22px;
  }

  #shopify-section-{{ section.id }} .map-split__card--top-center{
    top: 22px;
    left: 50%;
    transform: translateX(-50%);
  }

  #shopify-section-{{ section.id }} .map-split__card--top-right{
    top: 22px;
    right: 22px;
  }

  #shopify-section-{{ section.id }} .map-split__card--middle-left{
    top: 50%;
    left: 22px;
    transform: translateY(-50%);
  }

  #shopify-section-{{ section.id }} .map-split__card--middle-center{
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  #shopify-section-{{ section.id }} .map-split__card--middle-right{
    top: 50%;
    right: 22px;
    transform: translateY(-50%);
  }

  #shopify-section-{{ section.id }} .map-split__card--bottom-left{
    bottom: 22px;
    left: 22px;
  }

  #shopify-section-{{ section.id }} .map-split__card--bottom-center{
    bottom: 22px;
    left: 50%;
    transform: translateX(-50%);
  }

  #shopify-section-{{ section.id }} .map-split__card--bottom-right{
    bottom: 22px;
    right: 22px;
  }

  #shopify-section-{{ section.id }} .map-split__card .banner__heading{
    margin: 0 0 10px;
  }

  #shopify-section-{{ section.id }} .map-split__card .banner__subheading{
    margin: 0 0 10px;
    opacity: .9;
  }

  #shopify-section-{{ section.id }} .map-split__card .banner__text{
    margin: 0 0 14px;
  }

  #shopify-section-{{ section.id }} .map-split__card .button{
    margin-top: 6px;
  }

  #shopify-section-{{ section.id }} .map-split__image img{
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: var(--image-position);
  }

  @media (max-width: 989px){
    #shopify-section-{{ section.id }} .map-split__header{
      display: flex;
    }

    #shopify-section-{{ section.id }} .map-split__grid{
      grid-template-columns: 1fr;
    }

    {% if section.settings.mobile_text_box_position == 'image_first' %}
      #shopify-section-{{ section.id }} .map-split__image{
        order: 1;
      }

      #shopify-section-{{ section.id }} .map-split__map{
        order: 2;
      }
    {% else %}
      #shopify-section-{{ section.id }} .map-split__map{
        order: 1;
      }

      #shopify-section-{{ section.id }} .map-split__image{
        order: 2;
      }
    {% endif %}

    {% if mobile_ratio != 'adapt' %}
      #shopify-section-{{ section.id }} .map-split__media{
        height: {{ mobile_ratio }};
      }
    {% else %}
      #shopify-section-{{ section.id }} .map-split__media{
        height: auto;
        padding-bottom: var(--ratio-percent);
      }

      #shopify-section-{{ section.id }} .map-split__media > *{
        position: absolute;
        inset: 0;
      }
    {% endif %}

    #shopify-section-{{ section.id }} .map-split__card{
      display: none;
    }

    #shopify-section-{{ section.id }} .map-split__image .map-split__media{
      height: auto;
      padding-bottom: var(--ratio-percent);
    }

    #shopify-section-{{ section.id }} .map-split__image .map-split__media > *{
      position: absolute;
      inset: 0;
    }

    #shopify-section-{{ section.id }} .map-split__image img{
      object-fit: contain;
    }
  }
</style>

<div class="section--padding{% if section.settings.show_divider %} section--divider{% endif %}">
  <div class="page-width{% if section.settings.full_width %} page-width--full-width{% endif %}">
    <div class="title-wrapper center map-split__header">
      {%- for block in section.blocks -%}
        {%- if block.type == 'heading' -%}
          <{{ block.settings.heading_tag }} class="eyebrow-heading__title" {{ block.shopify_attributes }}>
            {%- render 'highlight-text',
              hl_input: block.settings.heading,
              hl_style: block.settings.highlight_style,
              hl_enable: block.settings.enable_highlight,
              hl_animateWrap: true
            -%}
          </{{ block.settings.heading_tag }}>
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}

      {%- for block in section.blocks -%}
        {%- if block.type == 'text' -%}
          <div class="map-split__header-address typeset rte">
            {%- render 'highlight-text',
              hl_input: block.settings.text,
              hl_style: block.settings.highlight_style,
              hl_enable: false,
              hl_animateWrap: true
            -%}
          </div>
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}

      {%- liquid
        assign mobile_hours_title = ''
        assign mobile_hours_html = ''
      -%}

      {%- for block in section.blocks -%}
        {%- if block.type == 'subheading' -%}
          {%- assign mobile_hours_title = block.settings.subheading -%}
        {%- elsif block.type == 'custom_liquid' and mobile_hours_html == blank -%}
          {%- assign mobile_hours_html = block.settings.custom_liquid -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if mobile_hours_html != blank -%}
        {%- if mobile_hours_title != blank -%}
          <p class="map-split__header-hours-title">{{ mobile_hours_title }}</p>
        {%- endif -%}

        <div class="map-split__header-hours rte">
          {{ mobile_hours_html }}
        </div>
      {%- endif -%}
    </div>

    <div class="map-split">
      <div class="map-split__grid">

        <!-- LEFT: GOOGLE MAPS BACKGROUND + CARD -->
        <div class="map-split__map">
          <div class="map-split__media">

            <div class="px-google-map-shell" aria-hidden="true"></div>

            <iframe
              class="px-google-map"
              title="Google Map"
              loading="lazy"
              allowfullscreen
              referrerpolicy="no-referrer-when-downgrade"
              src="https://maps.google.com/maps?q={{ dest_encoded }}&z={{ section.settings.map_zoom }}&output=embed">
            </iframe>

            {%- if section.blocks.size > 0 -%}
              <div class="map-split__card map-split__card--{{ section.settings.text_box_position }} {{ section.settings.text_alignment }} mobile-{{ section.settings.mobile_text_alignment }}">
                {%- for block in section.blocks -%}
                  {%- case block.type -%}

                    {%- when 'heading' -%}
                      <{{ block.settings.heading_tag }} class="banner__heading {{ block.settings.heading_size }}" {{ block.shopify_attributes }}>
                        {%- render 'highlight-text',
                          hl_input: block.settings.heading,
                          hl_style: block.settings.highlight_style,
                          hl_enable: block.settings.enable_highlight,
                          hl_animateWrap: true
                        -%}
                      </{{ block.settings.heading_tag }}>

                    {%- when 'subheading' -%}
                      <p class="banner__subheading{% if block.settings.secondary_color %} banner__subheading--colored{% endif %} {{ block.settings.subheading_size }}" {{ block.shopify_attributes }}>
                        {%- render 'highlight-text',
                          hl_input: block.settings.subheading,
                          hl_style: block.settings.highlight_style,
                          hl_enable: block.settings.enable_highlight,
                          hl_animateWrap: true
                        -%}
                      </p>

                    {%- when 'text' -%}
                      <div class="banner__text{% if block.settings.secondary_color %} image-with-text__text--colored{% endif %} {{ block.settings.text_size }} rte" {{ block.shopify_attributes }}>
                        {%- render 'highlight-text',
                          hl_input: block.settings.text,
                          hl_style: block.settings.highlight_style,
                          hl_enable: block.settings.enable_highlight,
                          hl_animateWrap: true
                        -%}
                      </div>

                    {%- when 'custom_liquid' -%}
                      <div class="banner__text rte" {{ block.shopify_attributes }}>
                        {{ block.settings.custom_liquid }}
                      </div>

                    {%- when 'button' -%}
                      {%- if block.settings.button_label != blank -%}
                        {%- assign button_href = block.settings.button_link -%}

                        {%- if button_href == blank -%}
                          {%- assign button_href = 'https://www.google.com/maps/dir/?api=1&destination=' | append: dest_encoded -%}
                        {%- endif -%}

                        {%- if block.settings.button_style_secondary -%}
                          <a
                            class="button button--cta button--{{ block.settings.button_size }}"
                            href="{{ button_href }}"
                            target="_blank"
                            rel="noopener"
                            {{ block.shopify_attributes }}>
                            <span class="label">{{ block.settings.button_label | escape }}</span>
                            {% render 'icon', icon: 'arrow' %}
                          </a>
                        {%- else -%}
                          <a
                            class="button button--{{ block.settings.button_size }}"
                            href="{{ button_href }}"
                            target="_blank"
                            rel="noopener"
                            {{ block.shopify_attributes }}>
                            {{ block.settings.button_label | escape }}
                          </a>
                        {%- endif -%}
                      {%- endif -%}

                  {%- endcase -%}
                {%- endfor -%}
              </div>
            {%- endif -%}

          </div>
        </div>

        <!-- RIGHT: SINGLE IMAGE -->
        <div class="map-split__image">
          <div class="map-split__media">
            {%- if section.settings.image != blank -%}
              {%- capture sizes -%}
                {% if section.settings.full_width %}
                  50vw
                {% else %}
                  (min-width: {{ settings.page_width }}px) {{ settings.page_width | divided_by: 2 }}px, 100vw
                {% endif %}
              {%- endcapture -%}

              {{ section.settings.image | image_url: width: 3840 | image_tag:
                loading: 'lazy',
                sizes: sizes,
                widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840'
              }}
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

{% schema %}
