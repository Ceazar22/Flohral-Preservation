{%- liquid
  assign mobile_cards_768 = section.settings.cards_mobile_768 | default: '3'

  if mobile_cards_768 == '4'
    assign mobile_card_divisor = '4.35'
    assign mobile_gap_count = 4
  else
    assign mobile_card_divisor = '3.35'
    assign mobile_gap_count = 3
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --image-position: {{ section.settings.image_position }};

    --rvp-mobile-gap: 16px;
    --rvp-mobile-card-width: calc((100% - (var(--rvp-mobile-gap) * {{ mobile_gap_count }})) / {{ mobile_card_divisor }});
    --rvp-mobile-one-card-width: calc(100% - 56px);
  }

  #shopify-section-{{ section.id }} .section--padding {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
  }

  #shopify-section-{{ section.id }} .title {
    font-weight: 600;
    color: #BB3263;
  }

  /*
    Mobile carousel only.
    No buttons/arrows.
    768px below = 3 or 4 cards with peek.
    450px below = 1 card with peek.
  */
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} slider-component,
    #shopify-section-{{ section.id }} .slider-mobile-gutter {
      display: block;
      max-width: 100%;
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .rvp-mobile-carousel {
      display: flex !important;
      grid-template-columns: none !important;
      flex-wrap: nowrap !important;
      gap: var(--rvp-mobile-gap) !important;
      overflow-x: auto !important;
      overflow-y: hidden !important;
      scroll-snap-type: x mandatory;
      scroll-padding-left: 0 !important;
      scroll-padding-right: 0 !important;
      -webkit-overflow-scrolling: touch;
      padding: 0 !important;
      margin: 0 !important;
      list-style: none;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    #shopify-section-{{ section.id }} .rvp-mobile-carousel::-webkit-scrollbar {
      display: none;
      height: 0;
    }

    #shopify-section-{{ section.id }} .rvp-mobile-carousel > .grid__item {
      flex: 0 0 var(--rvp-mobile-card-width) !important;
      width: var(--rvp-mobile-card-width) !important;
      min-width: var(--rvp-mobile-card-width) !important;
      max-width: var(--rvp-mobile-card-width) !important;
      scroll-snap-align: start;
      padding: 0 !important;
      margin: 0 !important;
    }
  }

  @media screen and (max-width: 450px) {
    #shopify-section-{{ section.id }} .rvp-mobile-carousel > .grid__item {
      flex: 0 0 var(--rvp-mobile-one-card-width) !important;
      width: var(--rvp-mobile-one-card-width) !important;
      min-width: var(--rvp-mobile-one-card-width) !important;
      max-width: var(--rvp-mobile-one-card-width) !important;
    }
  }
{%- endstyle -%}

<link rel="stylesheet" href="{{ 'component-card.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-product-grid.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-slider.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'section-recently-viewed-products.css' | asset_url }}" media="print" onload="this.media='all'">

{%- if settings.quick_view_enabled and section.settings.enable_quick_view -%}
  <link rel="stylesheet" href="{{ 'section-main-product.css' | asset_url }}" media="print" onload="this.media='all'">
  <link rel="stylesheet" href="{{ 'component-deferred-media.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

<noscript>{{ 'component-card.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-price.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-product-grid.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'section-recently-viewed-products.css' | asset_url | stylesheet_tag }}</noscript>

<recently-viewed-products
  class="recently-viewed-products"
  data-url="{{ routes.search_url }}?section_id={{ section.id }}&type=product&q="
  {% if request.page_type == 'product' %}
    data-product-id="{{ product.id }}"
  {% endif %}
>
  {%- if request.page_type == 'search' and search.performed and search.results_count > 0 -%}
    <div class="section--padding{% if section.settings.show_divider %} section--divider{% endif %}">
      <div class="page-width">
        <div class="title-wrapper{% if section.settings.heading == blank %} title-wrapper--no-heading{% endif %} {{ section.settings.heading_alignment }}">
          <{{ section.settings.heading_tag }} class="title {{ section.settings.heading_size }}">
            {{ section.settings.heading | capitalize | escape }}
          </{{ section.settings.heading_tag }}>
        </div>

        {%- assign parsed_terms = search.terms | split: ' OR ' -%}

        <slider-component class="slider-mobile-gutter">
          <ul
            id="Slider-{{ section.id }}"
            class="product-grid grid grid--2-col grid--3-col-tablet grid--4-col-desktop rvp-mobile-carousel{% if section.settings.columns_mobile == '1' %} grid--1-col-mobile{% endif %}"
            role="list"
          >
            {%- for parsed_term in parsed_terms -%}
              {%- assign id = parsed_term | split: 'id:' | last | times: 1 -%}

              {%- for product in search.results -%}
                {%- if product.id == id -%}
                  <li id="Slide-{{ section.id }}-{{ forloop.index }}" class="grid__item">
                    {% render 'card-product',
                      card_product: product,
                      card_collection: collection,
                      media_size: section.settings.image_ratio,
                      show_secondary_image: section.settings.show_secondary_image,
                      show_quick_buy: false,
                      show_vendor: section.settings.show_vendor,
                      show_rating: section.settings.show_rating,
                      show_price: false,
                      enable_quick_view: false,
                      enable_color_swatches: section.settings.enable_color_swatches,
                      enable_countdown: section.settings.enable_countdown,
                      enable_image_fill: section.settings.enable_image_fill
                    %}
                  </li>

                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endfor -%}
          </ul>
        </slider-component>
      </div>
    </div>
  {%- endif -%}
</recently-viewed-products>

