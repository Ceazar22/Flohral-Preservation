{% comment %}
  Section: In Love Newsletter (background image + centered card + optional feature bar)
  Updates:
  - Added section min-height control
  - Added heading bold toggle
{% endcomment %}

<section id="shopify-section-{{ section.id }}" class="inlove-newsletter">
  {%- style -%}
    #shopify-section-{{ section.id }}.inlove-newsletter {
      --pt: {{ section.settings.padding_top }}px;
      --pb: {{ section.settings.padding_bottom }}px;

      /* NEW: section height */
      --min-h: {{ section.settings.section_min_height }}px;

      --bg-color: {{ section.settings.background_color }};
      --bg-pos: {{ section.settings.background_position }};
      --overlay: {{ section.settings.background_overlay | divided_by: 100.0 }};

      --card-max: {{ section.settings.card_max_width }}px;
      --card-pad: {{ section.settings.card_padding }}px;
      --card-radius: {{ section.settings.card_radius }}px;
      --card-bg: {{ section.settings.card_bg }};
      --card-border: {{ section.settings.card_border }};
      --heading-color: {{ section.settings.heading_color }};
      --text-color: {{ section.settings.text_color }};

      --input-border: {{ section.settings.input_border }};
      --button-bg: {{ section.settings.button_bg }};
      --button-text: {{ section.settings.button_text }};

      --bar-bg: {{ section.settings.bar_bg }};
      --bar-text: {{ section.settings.bar_text }};
      --bar-divider: {{ section.settings.bar_divider }};
    }

    #shopify-section-{{ section.id }} .inlove-newsletter__wrap {
      padding-top: var(--pt);
      padding-bottom: var(--pb);
      background-color: var(--bg-color);
      position: relative;
      overflow: hidden;

      /* NEW: height */
      min-height: var(--min-h);

      /* keeps card centered vertically when height increases */
      display: flex;
      align-items: center;
    }

    #shopify-section-{{ section.id }} .inlove-newsletter__wrap::before {
      content: "";
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,var(--overlay)), rgba(255,255,255,var(--overlay))),
        url({% if section.settings.background_image %}{{ section.settings.background_image | image_url: width: 2400 }}{% else %}""{% endif %});
      background-size: cover;
      background-repeat: no-repeat;
      background-position: var(--bg-pos);
      z-index: 0;
    }

    #shopify-section-{{ section.id }} .inlove-newsletter__inner {
      position: relative;
      z-index: 1;
      display: flex;
      justify-content: center;
      width: 100%;
    }

    #shopify-section-{{ section.id }} .inlove-newsletter__card {
      width: min(100%, var(--card-max));
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: var(--card-radius);
      padding: var(--card-pad);
      text-align: center;
      box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    }

    #shopify-section-{{ section.id }} .inlove-newsletter__heading {
      margin: 0 0 8px;
      color: var(--heading-color);
      line-height: 1.15;

      /* NEW: bold toggle */
      font-weight: {% if section.settings.heading_bold %}700{% else %}400{% endif %};
    }

    #shopify-section-{{ section.id }} .inlove-newsletter__text {
      margin: 0 0 18px;
      color: var(--text-color);
      line-height: 1.4;
    }

    #shopify-section-{{ section.id }} .inlove-newsletter__form {
      max-width: 520px;
      margin: 0 auto;
    }

    #shopify-section-{{ section.id }} .inlove-newsletter__fields {
      display: grid;
      grid-template-columns: 1fr 160px;
      gap: 12px;
      align-items: center;
    }

    #shopify-section-{{ section.id }} .inlove-newsletter__input {
      width: 100%;
      min-height: 44px;
      padding: 10px 12px;
      border: 1px solid var(--input-border);
      border-radius: 2px;
      background: #fff;
      color: #111;
    }

    #shopify-section-{{ section.id }} .inlove-newsletter__button {
      min-height: 44px;
      padding: 10px 14px;
      border: 1px solid var(--button-bg);
      border-radius: 2px;
      background: var(--button-bg);
      color: var(--button-text);
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      cursor: pointer;
      width: 100%;
    }

    #shopify-section-{{ section.id }} .inlove-newsletter__msg {
      margin-top: 12px;
      font-size: 14px;
      color: var(--text-color);
    }

    /* Feature bar */
    #shopify-section-{{ section.id }} .inlove-newsletter__bar {
      background: var(--bar-bg);
      color: var(--bar-text);
      position: relative;
      z-index: 1;
    }

    #shopify-section-{{ section.id }} .inlove-newsletter__bar-inner {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0;
    }

    #shopify-section-{{ section.id }} .inlove-newsletter__bar-item {
      padding: 12px 10px;
      text-align: center;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      line-height: 1.2;
      position: relative;
    }

    #shopify-section-{{ section.id }} .inlove-newsletter__bar-item:not(:first-child)::before {
      content: "";
      position: absolute;
      left: 0;
      top: 20%;
      bottom: 20%;
      width: 1px;
      background: var(--bar-divider);
      opacity: 1;
    }

    /* Responsive */
    @media (max-width: 749px) {
      #shopify-section-{{ section.id }} .inlove-newsletter__fields {
        grid-template-columns: 1fr;
      }
      #shopify-section-{{ section.id }} .inlove-newsletter__bar-inner {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      #shopify-section-{{ section.id }} .inlove-newsletter__bar-item:not(:first-child)::before {
        display: none;
      }
    }
  {%- endstyle -%}

  <div class="inlove-newsletter__wrap">
    <div class="inlove-newsletter__inner page-width">
      <div class="inlove-newsletter__card">
        <h2 class="inlove-newsletter__heading {{ section.settings.heading_size }}">
          {{ section.settings.heading | escape }}
        </h2>

        {% if section.settings.text != blank %}
          <div class="inlove-newsletter__text">
            {{ section.settings.text }}
          </div>
        {% endif %}

        {% form 'customer', class: 'inlove-newsletter__form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">

          <div class="inlove-newsletter__fields">
            <label class="visually-hidden" for="NewsletterEmail-{{ section.id }}">
              {{ 'newsletter.label' | t | default: 'Email' }}
            </label>
            <input
              id="NewsletterEmail-{{ section.id }}"
              class="inlove-newsletter__input"
              type="email"
              name="contact[email]"
              value="{{ form.email }}"
              autocapitalize="off"
              autocomplete="email"
              placeholder="{{ section.settings.placeholder | escape }}"
              required
            >
            <button class="inlove-newsletter__button" type="submit" name="commit">
              {{ section.settings.button_label | escape }}
            </button>
          </div>

          {% if form.posted_successfully? %}
            <div class="inlove-newsletter__msg" role="status">
              {{ section.settings.success_message | escape }}
            </div>
          {% elsif form.errors %}
            <div class="inlove-newsletter__msg" role="alert">
              {{ form.errors | default_errors }}
            </div>
          {% endif %}
        {% endform %}
      </div>
    </div>
  </div>

  {% if section.settings.show_bar and section.blocks.size > 0 %}
    <div class="inlove-newsletter__bar">
      <div class="page-width inlove-newsletter__bar-inner">
        {% for block in section.blocks %}
          {% if block.type == 'feature' %}
            <div class="inlove-newsletter__bar-item" {{ block.shopify_attributes }}>
              {{ block.settings.text | escape }}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "In Love Newsletter",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "In Love?" },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "Large" },
        { "value": "h2", "label": "Medium" },
        { "value": "h3", "label": "Small" }
      ]
    },

    /* NEW: heading bold toggle */
    { "type": "checkbox", "id": "heading_bold", "label": "Make heading bold", "default": true },

    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Say “I do” to keeping in touch. Sign up for exclusive access, latest promos and new keepsakes.</p>"
    },
    { "type": "text", "id": "placeholder", "label": "Email placeholder", "default": "Enter your email address" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Join us" },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "Thanks for signing up!" },

    { "type": "header", "content": "Background" },
    { "type": "image_picker", "id": "background_image", "label": "Background image" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#ffffff" },
    {
      "type": "select",
      "id": "background_position",
      "label": "Background position",
      "default": "center",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" },
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "background_overlay",
      "label": "White overlay (helps readability)",
      "min": 0,
      "max": 60,
      "step": 5,
      "default": 0,
      "unit": "%"
    },

    { "type": "header", "content": "Card styling" },
    {
      "type": "range",
      "id": "card_max_width",
      "label": "Card max width",
      "min": 320,
      "max": 1200,
      "step": 20,
      "default": 900
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card padding",
      "min": 16,
      "max": 80,
      "step": 4,
      "default": 44
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "default": 2
    },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#ffffff" },
    { "type": "color", "id": "card_border", "label": "Card border", "default": "#e6e6e6" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#c23368" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#555555" },

    { "type": "header", "content": "Form styling" },
    { "type": "color", "id": "input_border", "label": "Input border", "default": "#d3d3d3" },
    { "type": "color", "id": "button_bg", "label": "Button background", "default": "#c23368" },
    { "type": "color", "id": "button_text", "label": "Button text", "default": "#ffffff" },

    { "type": "header", "content": "Feature bar" },
    { "type": "checkbox", "id": "show_bar", "label": "Show feature bar", "default": true },
    { "type": "color", "id": "bar_bg", "label": "Bar background", "default": "#b62b5b" },
    { "type": "color", "id": "bar_text", "label": "Bar text", "default": "#ffffff" },
    { "type": "color", "id": "bar_divider", "label": "Divider color", "default": "rgba(255,255,255,0.35)" },

    { "type": "header", "content": "Spacing" },

    /* NEW: section min height */
    {
      "type": "range",
      "id": "section_min_height",
      "label": "Section min height",
      "min": 0,
      "max": 900,
      "step": 20,
      "default": 0,
      "unit": "px"
    },

    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "default": 40 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "default": 40 }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature item",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Woman owned and operated" }
      ]
    }
  ],
  "presets": [
    {
      "name": "In Love Newsletter",
      "blocks": [
        { "type": "feature" },
        { "type": "feature", "settings": { "text": "Trusted by top florists in New York" } },
        { "type": "feature", "settings": { "text": "Limited spots each month" } },
        { "type": "feature", "settings": { "text": "VIP communication & custom service" } }
      ]
    }
  ]
}
{% endschema %}
