{%- liquid
  assign show_popup = true

  if section.settings.only_homepage and request.page_type != 'index'
    assign show_popup = false
  endif
-%}

{%- if show_popup -%}
  {%- style -%}
    promo-popup,
    .promo-popup {
      z-index: 9999 !important;
    }

    .exit-popup {
      display: flex;
      width: min(1200px, 95vw) !important;
      height: min(600px, 85vh) !important;
      overflow: hidden;
    }

    .exit-popup__image-side {
      position: relative;
      flex: 0 0 50%;
      overflow: hidden;
    }

    .exit-popup__image-side img,
    .exit-popup__image-side svg {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      display: block;
    }

    .exit-popup__badge {
      position: absolute;
      top: 1.4rem;
      left: 1.4rem;
      background: #fff;
      color: #1a1b18;
      font-size: 1rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 0.5rem 1.2rem;
      border-radius: 50px;
      z-index: 2;
      box-shadow: 0 1px 6px rgba(0,0,0,0.12);
    }

    .exit-popup__content-side {
      flex: 1 1 50%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 3rem 3.5rem;
      background: #fff;
    }

    .exit-popup__eyebrow {
      font-size: 1.05rem;
      letter-spacing: 0.2em;
      color: #aaa;
      text-transform: uppercase;
      margin: 0 0 1.2rem;
      font-weight: 500;
    }

    .exit-popup__heading {
      font-size: clamp(2.2rem, 3vw, 2.8rem);
      line-height: 1.18;
      font-weight: 700;
      color: #1a1b18;
      margin: 0 0 1rem;
    }

    .exit-popup__subtext {
      font-size: 1.3rem;
      color: #888;
      line-height: 1.6;
      margin: 0 0 1.5rem;
    }

    .exit-popup__form-wrapper {
      width: 100%;
      min-height: 400px;
    }

    .exit-popup__form-wrapper iframe {
      width: 100%;
      min-height: 400px !important;
      border: none;
      display: block;
    }

    @media screen and (max-width: 749px) {
      .exit-popup {
        flex-direction: column;
        width: 95vw;
      }

      .exit-popup__image-side {
        flex: 0 0 220px;
        min-height: unset;
      }

      .exit-popup__content-side {
        padding: 2rem 1.8rem;
      }

      .exit-popup__heading {
        font-size: 2rem;
      }
    }

    @media screen and (max-width: 767px) {
      .promo-popup {
        padding: 0 !important;
        align-items: stretch !important;
        justify-content: stretch !important;
      }

      .popup-wrapper {
        width: 100vw !important;
        max-width: 100vw !important;
        height: 100dvh !important;
        max-height: 100dvh !important;
        align-self: stretch !important;
      }

      .popup.exit-popup {
        flex-direction: column !important;
        width: 100vw !important;
        height: 100dvh !important;
        max-height: 100dvh !important;
      }

      .exit-popup__image-side {
        flex: 0 0 38% !important;
        min-height: unset !important;
      }

      .exit-popup__content-side {
        flex: 1 1 auto !important;
        padding: 1.5rem !important;
        overflow-y: auto !important;
        justify-content: flex-start !important;
      }

      .exit-popup__heading {
        font-size: 1.8rem !important;
      }

      .exit-popup__subtext {
        font-size: 1.2rem !important;
        margin-bottom: 1rem !important;
      }

      .exit-popup__form-wrapper,
      .exit-popup__form-wrapper iframe {
        min-height: 360px !important;
      }

      .popup-close {
        top: 0.5rem !important;
        right: 0.5rem !important;
        z-index: 10 !important;
      }
    }
  {%- endstyle -%}

  <link rel="stylesheet" href="{{ 'section-popup.css' | asset_url }}" media="print" onload="this.media='all'">
  <noscript>{{ 'section-popup.css' | asset_url | stylesheet_tag }}</noscript>
  <script src="{{ 'popup.js' | asset_url }}" defer="defer"></script>

  <promo-popup data-section-id="{{ section.id }}" class="hidden" data-delay="{{ section.settings.delay }}" data-expiry="{{ section.settings.expiry }}" data-test-mode="true">
    <div class="promo-popup" data-position="center">
      <div class="popup-overlay" data-popup-toggle></div>
      <div class="popup-wrapper">
        <button class="popup-close" type="button" aria-label="{{ 'accessibility.close' | t }}" data-popup-toggle>
          <span class="icon icon-plus-alt"></span>
        </button>
        <div class="popup exit-popup">

          <div class="exit-popup__image-side">
            <span class="exit-popup__badge">LIMITED SPOT</span>
            {%- if section.settings.image != blank -%}
              {{ section.settings.image | image_url: width: 900 | image_tag:
                loading: 'lazy',
                is: 'lazy-image',
                alt: 'Flohral preserved bouquet'
              }}
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder' }}
            {%- endif -%}
          </div>

          <div class="exit-popup__content-side">
            <p class="exit-popup__eyebrow">WAIT, BEFORE YOU GO</p>
            <h2 class="exit-popup__heading">Don't let your bouquet fade away forever.</h2>
            <p class="exit-popup__subtext">Join brides who preserve their wedding day beautifully get updates about our new arrivals, special promotions and online exclusives.</p>
            <div class="exit-popup__form-wrapper">
              <iframe
                src="https://the.flohralpreservation.com/widget/form/pZg0bjnK6wik5PaPA9hT"
                style="width:100%;height:100%;border:none;border-radius:0px"
                id="inline-pZg0bjnK6wik5PaPA9hT"
                data-layout="{'id':'INLINE'}"
                data-trigger-type="alwaysShow"
                data-trigger-value=""
                data-activation-type="alwaysActivated"
                data-activation-value=""
                data-deactivation-type="neverDeactivate"
                data-deactivation-value=""
                data-form-name="Shopify Exit Pop Up ✅"
                data-height="400"
                data-layout-iframe-id="inline-pZg0bjnK6wik5PaPA9hT"
                data-form-id="pZg0bjnK6wik5PaPA9hT"
                title="Shopify Exit Pop Up ✅"
              ></iframe>
              <script src="https://the.flohralpreservation.com/js/form_embed.js"></script>
            </div>
          </div>

        </div>
      </div>
    </div>
  </promo-popup>
{%- endif -%}

