{%- liquid
  if linklists.gift-wrapping.links != blank and linklists.gift-wrapping.links.first.type == 'product_link'
    assign gift_wrapping = linklists.gift-wrapping.links.first

    assign gift_wrap_id = gift_wrapping.object.variants.first.id
    assign gift_wraps_in_cart = 0
    for item in cart.items
      if item.id == gift_wrap_id
        assign gift_wraps_in_cart = item.quantity
        break
      endif
    endfor
    assign items_in_cart = cart.item_count | minus: gift_wraps_in_cart
  endif

  assign minimum_checkout_amount_cents = section.settings.minimum_checkout_amount | times: 100 | round
  assign minimum_checkout_is_met = true
  assign minimum_checkout_remaining = 0

  if section.settings.enable_minimum_checkout
    if cart == empty
      assign minimum_checkout_is_met = false
      assign minimum_checkout_remaining = minimum_checkout_amount_cents
    elsif cart.total_price < minimum_checkout_amount_cents
      assign minimum_checkout_is_met = false
      assign minimum_checkout_remaining = minimum_checkout_amount_cents | minus: cart.total_price
    else
      assign minimum_checkout_is_met = true
      assign minimum_checkout_remaining = 0
    endif
  endif

  assign retainer_paid_discount_amount = 0
  assign subtotal_before_retainer_paid = 0

  for item in cart.items
    assign subtotal_before_retainer_paid = subtotal_before_retainer_paid | plus: item.original_line_price

    if item.line_level_discount_allocations.size > 0
      for discount_allocation in item.line_level_discount_allocations
        if discount_allocation.discount_application.title == 'Retainer Paid'
          assign retainer_paid_discount_amount = retainer_paid_discount_amount | plus: discount_allocation.amount
        endif
      endfor
    endif
  endfor
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .cart-minimum-order {
    width: 100%;
    margin: 0 0 16px;
    padding: 13px 15px;
    border: 1px solid {{ section.settings.minimum_message_border_color }};
    border-radius: 4px;
    background-color: {{ section.settings.minimum_message_background_color }};
    color: {{ section.settings.minimum_message_text_color }};
  }

  #shopify-section-{{ section.id }} .cart-minimum-order__text {
    margin: 0;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.45;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .cart-minimum-order__text strong {
    font-weight: 600;
  }

  #shopify-section-{{ section.id }} .cart__checkout-button[disabled] {
    opacity: 0.45;
    cursor: not-allowed;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .cart-retainer-paid-summary {
    margin: 10px 0 0;
  }

  #shopify-section-{{ section.id }} .cart-retainer-paid-summary__discount {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin: 8px 0 0;
    font-size: 14px;
  }

  #shopify-section-{{ section.id }} .cart-retainer-paid-summary__discount-label {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  #shopify-section-{{ section.id }} .cart-retainer-paid-summary__discount-value {
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .cart-retainer-paid-summary__total {
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid rgba(var(--color-foreground), 0.14);
  }
{%- endstyle -%}

{{ 'component-cart.css' | asset_url | stylesheet_tag }}
{{ 'component-totals.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-discounts.css' | asset_url | stylesheet_tag }}

<div
  class="page-width{% if cart == empty %} is-empty{% endif %} section--padding"
  id="main-cart-footer"
  data-id="{{ section.id }}"
  data-cart-footer
  data-section-id="{{ section.id }}"
  data-minimum-checkout-enabled="{{ section.settings.enable_minimum_checkout }}"
  data-minimum-checkout-cents="{{ minimum_checkout_amount_cents }}"
  data-cart-currency="{{ cart.currency.iso_code }}"
>
  <div class="cart__footer">
    <div>
      {%- if gift_wrapping != nil -%}
        <gift-wrapping
          class="gift-wrapping"
          data-gift-wrap-id="{{ gift_wrap_id }}"
          data-gift-wrapping="{{ cart.attributes.gift-wrapping | escape }}"
          cart-items-size="{{ cart.items.size }}"
          gift-wraps-in-cart="{{ gift_wraps_in_cart }}"
          items-in-cart="{{ items_in_cart }}"
        >
          <input
            id="gift-wrapping"
            type="checkbox"
            name="attributes[gift-wrapping]"
            value="yes"
            {% if cart.attributes.gift-wrapping %}
              checked="checked"
            {% endif %}
            class="visually-hidden"
          />

          <label for="gift-wrapping" class="gift-wrapping__label">
            {%- capture gift_price -%}
              <price-money class="price">
                <bdi>
                  {% if settings.currency_code_enabled %}
                    {{ gift_wrapping.object.price | money_with_currency }}
                  {% else %}
                    {{ gift_wrapping.object.price | money }}
                  {% endif %}
                </bdi>
              </price-money>
            {%- endcapture -%}

            <span class="gift-wrapping__text">
              {{ 'sections.cart.gift_wrapping_html' | t: price: gift_price }}
            </span>

            <div class="loading-overlay hidden">
              <div class="loading-overlay__spinner">
                {% render 'icon', icon: 'spinner' %}
              </div>
            </div>

            {% render 'icon', icon: 'checkmark', class: 'gift-wrapping__icon' %}
          </label>

          {%- if cart.attributes.gift-wrapping -%}
            <gift-note class="gift-wrapping__note">
              <textarea
                class="text-area text-area--resize-vertical field__input"
                name="attributes[gift-note]"
                id="gift-note"
                placeholder="{{ 'sections.cart.gift_note_placeholder' | t }}"
              >{{ cart.attributes.gift-note }}</textarea>
            </gift-note>
          {%- endif -%}
        </gift-wrapping>
      {%- endif -%}

      {%- if section.settings.show_cart_note -%}
        <cart-note class="cart__note field">
          <label for="Cart-note">{{ 'sections.cart.note' | t }}</label>
          <textarea
            class="text-area text-area--resize-vertical field__input"
            name="note"
            id="Cart-note"
            placeholder="{{ 'sections.cart.note_placeholder' | t }}"
          >{{ cart.note }}</textarea>
        </cart-note>
      {%- endif -%}
    </div>

    <div>
      {% for block in section.blocks %}
        {%- case block.type -%}
          {%- when 'subtotal' -%}
            <div class="js-contents" {{ block.shopify_attributes }}>
              {%- if retainer_paid_discount_amount > 0 -%}
                <div class="totals">
                  <p class="totals__subtotal h3">{{ 'sections.cart.subtotal' | t }}</p>
                  <p class="totals__subtotal-value">
                    {{ subtotal_before_retainer_paid | money_with_currency }}
                  </p>
                </div>

                <div class="cart-retainer-paid-summary">
                  <div class="cart-retainer-paid-summary__discount">
                    <span class="cart-retainer-paid-summary__discount-label">
                      {% render 'icon', icon: 'discount' %}
                      Retainer Paid
                    </span>

                    <span class="cart-retainer-paid-summary__discount-value">
                      &minus;{{ retainer_paid_discount_amount | money_with_currency }}
                    </span>
                  </div>

                  <div class="totals cart-retainer-paid-summary__total">
                    <p class="totals__subtotal h3">Subtotal after credit</p>
                    <p class="totals__subtotal-value">
                      {{ cart.total_price | money_with_currency }}
                    </p>
                  </div>
                </div>
              {%- else -%}
                <div class="totals">
                  <p class="totals__subtotal h3">{{ 'sections.cart.subtotal' | t }}</p>
                  <p class="totals__subtotal-value">{{ cart.total_price | money_with_currency }}</p>
                </div>
              {%- endif -%}

              <div>
                {%- if cart.cart_level_discount_applications.size > 0 -%}
                  <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                    {%- for discount in cart.cart_level_discount_applications -%}
                      <li class="discounts__discount discounts__discount--end">
                        {% render 'icon', icon: 'discount' %}
                        {{ discount.title }}
                        (&#8211;{{ discount.total_allocated_amount | money }})
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </div>

              <small class="tax-note caption-large rte">
                {%- if cart.duties_included and cart.taxes_included -%}
                  {%- if shop.shipping_policy.body == blank -%}
                    {{ 'sections.cart.duties_and_taxes_included_shipping_at_checkout_without_policy' | t }}
                  {%- else -%}
                    {{
                      'sections.cart.duties_and_taxes_included_shipping_at_checkout_with_policy_html'
                      | t: link: shop.shipping_policy.url
                    }}
                  {%- endif -%}
                {%- elsif cart.duties_included == false and cart.taxes_included -%}
                  {%- if shop.shipping_policy.body == blank -%}
                    {{ 'sections.cart.taxes_included_shipping_at_checkout_without_policy' | t }}
                  {%- else -%}
                    {{
                      'sections.cart.taxes_included_shipping_at_checkout_with_policy_html'
                      | t: link: shop.shipping_policy.url
                    }}
                  {%- endif -%}
                {%- elsif cart.duties_included and cart.taxes_included == false -%}
                  {%- if shop.shipping_policy.body == blank -%}
                    {{ 'sections.cart.duties_included_taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
                  {%- else -%}
                    {{
                      'sections.cart.duties_included_taxes_at_checkout_shipping_at_checkout_with_policy_html'
                      | t: link: shop.shipping_policy.url
                    }}
                  {%- endif -%}
                {%- elsif cart.duties_included == false and cart.taxes_included == false -%}
                  {%- if shop.shipping_policy.body == blank -%}
                    {{ 'sections.cart.taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
                  {%- else -%}
                    {{
                      'sections.cart.taxes_at_checkout_shipping_at_checkout_with_policy_html'
                      | t: link: shop.shipping_policy.url
                    }}
                  {%- endif -%}
                {%- endif -%}
              </small>
            </div>

          {%- when 'buttons' -%}
            {%- if section.settings.enable_minimum_checkout -%}
              <div
                class="cart-minimum-order"
                role="status"
                aria-live="polite"
                data-cart-minimum-order
              >
                <p class="cart-minimum-order__text" data-cart-minimum-text>
                  {%- if cart == empty -%}
                    Minimum order is
                    <strong>{{ minimum_checkout_amount_cents | money_with_currency }}</strong>
                    to continue to checkout.
                  {%- elsif minimum_checkout_is_met == false -%}
                    Minimum order is
                    <strong>{{ minimum_checkout_amount_cents | money_with_currency }}</strong>.
                    Add
                    <strong>{{ minimum_checkout_remaining | money_with_currency }}</strong>
                    more to continue to checkout.
                  {%- else -%}
                    Minimum order is
                    <strong>{{ minimum_checkout_amount_cents | money_with_currency }}</strong>.
                    You are ready to checkout.
                  {%- endif -%}
                </p>
              </div>
            {%- endif -%}

            <div class="cart__ctas" {{ block.shopify_attributes }}>
              <noscript>
                <button type="submit" class="cart__update-button button button--secondary" form="cart">
                  {{ 'sections.cart.update' | t }}
                </button>
              </noscript>

              <button
                type="submit"
                class="cart__checkout-button button"
                name="checkout"
                form="cart"
                data-cart-checkout-button
                {% if cart == empty or minimum_checkout_is_met == false %}
                  disabled="disabled"
                  aria-disabled="true"
                {% endif %}
              >
                {{ 'sections.cart.checkout' | t }}
              </button>
            </div>

            {%- if additional_checkout_buttons and block.settings.show_dynamic_checkout and minimum_checkout_is_met and cart != empty -%}
              <div class="cart__dynamic-checkout-buttons additional-checkout-buttons" data-dynamic-checkout-buttons>
                {{ content_for_additional_checkout_buttons }}
              </div>
            {%- endif -%}

          {%- when 'free_shipping' -%}
            {%- liquid
              if block.settings.minimum_amount != blank
                assign free_shipping_minimum_amounts = block.settings.minimum_amount | remove: ' ' | split: ','
                assign show_free_shipping_message = false

                if free_shipping_minimum_amounts.size > 1
                  for minimum_amount in free_shipping_minimum_amounts
                    assign minimum_amount_parts = minimum_amount | split: ':'
                    assign currency_code = minimum_amount_parts | first | upcase
                    if currency_code == cart.currency.iso_code
                      assign free_shipping_minimum_amount = minimum_amount_parts | last
                      assign show_free_shipping_message = true
                      break
                    endif
                  endfor
                else
                  assign free_shipping_minimum_amount = free_shipping_minimum_amounts | last
                  if free_shipping_minimum_amount contains ':'
                    assign free_shipping_minimum_amount = free_shipping_minimum_amounts | split: ':' | last
                  endif
                  assign show_free_shipping_message = true
                endif

                if show_free_shipping_message
                  render 'free-shipping', minimum_amount: free_shipping_minimum_amount, is_last: forloop.last
                endif
              endif
            -%}
        {%- endcase -%}
      {% endfor %}

      <div id="cart-errors" class="form__message errors"></div>
    </div>
  </div>
</div>

<script>
  (function () {
    var refreshTimer = null;
    var isRefreshing = false;

    function getCartFooter() {
      return document.querySelector('[data-cart-footer]');
    }

    function formatMoney(cents, currency) {
      var amount = Number(cents || 0) / 100;
      var currencyCode = currency || 'USD';

      try {
        return new Intl.NumberFormat(undefined, {
          style: 'currency',
          currency: currencyCode
        }).format(amount) + ' ' + currencyCode;
      } catch (error) {
        return '$' + amount.toFixed(2) + ' ' + currencyCode;
      }
    }

    function updateMinimumFromCart(cart) {
      var footer = getCartFooter();

      if (!footer || footer.dataset.minimumCheckoutEnabled !== 'true') {
        return;
      }

      var minimumCents = parseInt(footer.dataset.minimumCheckoutCents || '0', 10);
      var currency = cart.currency || footer.dataset.cartCurrency || 'USD';
      var totalPrice = Number(cart.total_price || 0);
      var itemCount = Number(cart.item_count || 0);
      var minimumText = footer.querySelector('[data-cart-minimum-text]');
      var checkoutButton = footer.querySelector('[data-cart-checkout-button]');
      var dynamicCheckout = footer.querySelector('[data-dynamic-checkout-buttons]');
      var isMinimumMet = itemCount > 0 && totalPrice >= minimumCents;
      var remaining = Math.max(minimumCents - totalPrice, 0);

      if (minimumText) {
        if (itemCount <= 0) {
          minimumText.innerHTML =
            'Minimum order is <strong>' +
            formatMoney(minimumCents, currency) +
            '</strong> to continue to checkout.';
        } else if (!isMinimumMet) {
          minimumText.innerHTML =
            'Minimum order is <strong>' +
            formatMoney(minimumCents, currency) +
            '</strong>. Add <strong>' +
            formatMoney(remaining, currency) +
            '</strong> more to continue to checkout.';
        } else {
          minimumText.innerHTML =
            'Minimum order is <strong>' +
            formatMoney(minimumCents, currency) +
            '</strong>. You are ready to checkout.';
        }
      }

      if (checkoutButton) {
        if (isMinimumMet) {
          checkoutButton.removeAttribute('disabled');
          checkoutButton.setAttribute('aria-disabled', 'false');
        } else {
          checkoutButton.setAttribute('disabled', 'disabled');
          checkoutButton.setAttribute('aria-disabled', 'true');
        }
      }

      if (dynamicCheckout) {
        dynamicCheckout.style.display = isMinimumMet ? '' : 'none';
      }
    }

    function fetchCartJson() {
      return fetch('/cart.js', {
        method: 'GET',
        headers: {
          Accept: 'application/json'
        },
        cache: 'no-store'
      }).then(function (response) {
        if (!response.ok) {
          throw new Error('Cart JSON failed');
        }

        return response.json();
      });
    }

    function refreshCartFooterSection() {
      var footer = getCartFooter();

      if (!footer || isRefreshing) {
        return;
      }

      isRefreshing = true;

      var sectionId = footer.dataset.sectionId || footer.dataset.id || '{{ section.id }}';
      var url = new URL(window.location.href);

      url.searchParams.set('sections', sectionId);

      fetch(url.toString(), {
        method: 'GET',
        headers: {
          Accept: 'application/json'
        },
        cache: 'no-store'
      })
        .then(function (response) {
          if (!response.ok) {
            throw new Error('Section refresh failed');
          }

          return response.json();
        })
        .then(function (sections) {
          if (!sections || !sections[sectionId]) {
            return;
          }

          var parser = new DOMParser();
          var doc = parser.parseFromString(sections[sectionId], 'text/html');
          var newFooter = doc.querySelector('[data-cart-footer]');
          var currentFooter = getCartFooter();

          if (newFooter && currentFooter) {
            currentFooter.innerHTML = newFooter.innerHTML;

            currentFooter.dataset.minimumCheckoutEnabled = newFooter.dataset.minimumCheckoutEnabled;
            currentFooter.dataset.minimumCheckoutCents = newFooter.dataset.minimumCheckoutCents;
            currentFooter.dataset.cartCurrency = newFooter.dataset.cartCurrency;
            currentFooter.dataset.sectionId = newFooter.dataset.sectionId;
            currentFooter.dataset.id = newFooter.dataset.id;
          }
        })
        .catch(function () {
          return fetchCartJson().then(updateMinimumFromCart);
        })
        .finally(function () {
          isRefreshing = false;

          fetchCartJson()
            .then(updateMinimumFromCart)
            .catch(function () {});
        });
    }

    function scheduleCartFooterRefresh(delay) {
      window.clearTimeout(refreshTimer);

      refreshTimer = window.setTimeout(function () {
        refreshCartFooterSection();
      }, delay || 700);
    }

    document.addEventListener('click', function (event) {
      var trigger = event.target.closest(
        '.quantity__button, .quantity button, button[name="plus"], button[name="minus"], cart-remove-button, a[href*="/cart/change"], button[name="update"]'
      );

      if (!trigger) {
        return;
      }

      scheduleCartFooterRefresh(900);
    });

    document.addEventListener('change', function (event) {
      if (
        event.target.matches('input[name="updates[]"]') ||
        event.target.matches('.quantity__input') ||
        event.target.matches('input[type="number"]')
      ) {
        scheduleCartFooterRefresh(900);
      }
    });

    document.addEventListener('input', function (event) {
      if (
        event.target.matches('input[name="updates[]"]') ||
        event.target.matches('.quantity__input') ||
        event.target.matches('input[type="number"]')
      ) {
        scheduleCartFooterRefresh(1000);
      }
    });

    document.addEventListener('cart:updated', function () {
      scheduleCartFooterRefresh(300);
    });

    document.addEventListener('cart:refresh', function () {
      scheduleCartFooterRefresh(300);
    });

    document.addEventListener('cart:change', function () {
      scheduleCartFooterRefresh(300);
    });

    document.addEventListener('shopify:section:load', function () {
      scheduleCartFooterRefresh(300);
    });

    window.addEventListener('pageshow', function () {
      scheduleCartFooterRefresh(300);
    });
  })();
</script>

{% schema %}
{
  "name": "t:sections.main-cart-footer.name",
  "tag": "section",
  "class": "section cart__footer-wrapper",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_cart_note",
      "default": false,
      "label": "t:sections.main-cart-footer.settings.show_cart_note.label"
    },
    {
      "type": "header",
      "content": "Minimum checkout order"
    },
    {
      "type": "checkbox",
      "id": "enable_minimum_checkout",
      "label": "Enable minimum checkout amount",
      "default": true
    },
    {
      "type": "number",
      "id": "minimum_checkout_amount",
      "label": "Minimum checkout amount",
      "default": 500,
      "info": "Enter the minimum amount in your store currency. Example: 500 means $500 USD."
    },
    {
      "type": "color",
      "id": "minimum_message_background_color",
      "label": "Minimum message background",
      "default": "#fbf2f5"
    },
    {
      "type": "color",
      "id": "minimum_message_border_color",
      "label": "Minimum message border",
      "default": "#bf3265"
    },
    {
      "type": "color",
      "id": "minimum_message_text_color",
      "label": "Minimum message text",
      "default": "#171717"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.header.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "t:sections.all.padding.padding_top.unit",
      "label": "t:sections.all.padding.padding_top.label",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "t:sections.all.padding.padding_bottom.unit",
      "label": "t:sections.all.padding.padding_bottom.label",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "subtotal",
      "name": "t:sections.main-cart-footer.blocks.subtotal.name",
      "limit": 1
    },
    {
      "type": "buttons",
      "name": "t:sections.main-cart-footer.blocks.buttons.name",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_dynamic_checkout",
          "default": true,
          "label": "t:sections.main-product.blocks.buy_buttons.settings.show_dynamic_checkout.label",
          "info": "t:sections.main-product.blocks.buy_buttons.settings.show_dynamic_checkout.info"
        }
      ]
    },
    {
      "type": "free_shipping",
      "name": "t:sections.main-cart-footer.blocks.free_shipping.name",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.main-cart-footer.blocks.free_shipping.settings.paragraph.content"
        },
        {
          "type": "text",
          "id": "minimum_amount",
          "default": "100",
          "label": "t:sections.main-cart-footer.blocks.free_shipping.settings.minimum_amount.label",
          "info": "t:sections.main-cart-footer.blocks.free_shipping.settings.minimum_amount.info"
        }
      ]
    }
  ]
}
{% endschema %}