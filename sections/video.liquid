{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;

    --color-highlight: {{ section.settings.colors_highlight.red }}, {{ section.settings.colors_highlight.green }}, {{ section.settings.colors_highlight.blue }};

    /* Frame */
    --video-frame-color: {{ section.settings.frame_color.red }}, {{ section.settings.frame_color.green }}, {{ section.settings.frame_color.blue }};
    --video-frame-thickness: {{ section.settings.frame_thickness }}px;
    --video-frame-padding: {{ section.settings.frame_padding }}px;
    --video-frame-radius: {{ section.settings.frame_radius }}px;

    /* Size */
    --video-max-width: {{ section.settings.video_max_width }}px;
    --video-heading-color: {{ section.settings.heading_color }};

    /* NEW: CTA button */
    --cta-bg: {{ section.settings.cta_bg.red }}, {{ section.settings.cta_bg.green }}, {{ section.settings.cta_bg.blue }};
    --cta-text: {{ section.settings.cta_text.red }}, {{ section.settings.cta_text.green }}, {{ section.settings.cta_text.blue }};
    --cta-radius: {{ section.settings.cta_radius }}px;
    --cta-pad-y: {{ section.settings.cta_padding_y }}px;
    --cta-pad-x: {{ section.settings.cta_padding_x }}px;
  }
{%- endstyle -%}

{{ 'section-video.css' | asset_url | stylesheet_tag }}
{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

<style>
  /* Force eyebrow + heading to STACK (some themes set title-wrapper to flex row) */
  #shopify-section-{{ section.id }} .title-wrapper{
    display: block !important;
    width: 100%;
  }

  /* Ensure the eyebrow takes full line */
  #shopify-section-{{ section.id }} .video-section__eyebrow{
    display: block;
    width: 100%;
    margin: 0 0 10px;
  }

  /* Header (eyebrow + description) */
  #shopify-section-{{ section.id }} .video-section__eyebrow{
    margin: 0 0 10px;
    font-size: 11px;
    letter-spacing: .22em;
    text-transform: uppercase;
    opacity: .8;
  }

  #shopify-section-{{ section.id }} .video-section__subheading{
    margin: 12px auto 0;
    max-width: 70ch;
    opacity: .85;
  }
  #shopify-section-{{ section.id }} .video-section__subheading p{ margin: 0; }
  #shopify-section-{{ section.id }} .video-section__subheading a{ text-decoration: underline; }

  /* Size wrapper */
  #shopify-section-{{ section.id }} .video-section__frame-wrap{
    width: 100%;
    margin: 0 auto;
  }
  #shopify-section-{{ section.id }} .video-section__frame-wrap--custom{
    max-width: min(var(--video-max-width), 100%);
  }

  /* Pink frame wrapper */
  #shopify-section-{{ section.id }} .video-section__frame {
    border: var(--video-frame-thickness) solid rgb(var(--video-frame-color));
    padding: var(--video-frame-padding);
    border-radius: var(--video-frame-radius);
    background: transparent;
    {% if section.settings.frame_shadow %}
      box-shadow: 0 10px 30px rgba(0,0,0,.18);
    {% endif %}
  }

  /* Ensure inner video corners match the frame nicely */
  #shopify-section-{{ section.id }} .video-section__frame .video-section__media {
    border-radius: clamp(0px, calc(var(--video-frame-radius) - var(--video-frame-padding)), var(--video-frame-radius));
    overflow: hidden;
  }

  /* Sometimes the poster is the thing that needs rounding */
  #shopify-section-{{ section.id }} .video-section__frame .video-section__poster {
    border-radius: inherit;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .video-section .title,
  #shopify-section-{{ section.id }} .video-section .title *{
    color: var(--video-heading-color);
  }

  /* NEW: CTA area under the video */
  #shopify-section-{{ section.id }} .video-section__cta{
    display: flex;
    justify-content: center;
    margin-top: 18px;
  }

  #shopify-section-{{ section.id }} .video-section__cta a{
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: .08em;
    font-weight: 700;
    font-size: 12px;
    line-height: 1;
    padding: var(--cta-pad-y) var(--cta-pad-x);
    border-radius: var(--cta-radius);
    background: rgb(var(--cta-bg));
    color: rgb(var(--cta-text));
    border: 1px solid rgba(0,0,0,.08);
    transition: transform .15s ease, opacity .15s ease;
  }

  #shopify-section-{{ section.id }} .video-section__cta a:hover{
    transform: translateY(-1px);
    opacity: .95;
  }

  #shopify-section-{{ section.id }} .video-section__cta a:focus-visible{
    outline: 2px solid rgba(var(--color-highlight), .8);
    outline-offset: 3px;
  }
</style>

{%- liquid
  assign video_id = section.settings.video.id | default: section.settings.video_url.id
  assign video_alt = section.settings.video.alt | default: section.settings.description
  assign alt = 'sections.video.load_video' | t: description: video_alt | escape
  assign poster = section.settings.video.preview_image | default: section.settings.cover_image

  if section.settings.video != null and poster != null
    assign ratio_diff = section.settings.video.aspect_ratio | minus: poster.aspect_ratio | abs
    if ratio_diff < 0.01 and ratio_diff > 0
      assign fix_ratio = true
    endif
  endif
-%}

{%- capture sizes -%}
  {% if section.settings.full_width -%}
    100vw
  {%- else -%}
    (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 }}px, (min-width: 750px)
    calc(100vw - 10rem), 100vw
  {%- endif %}
{%- endcapture -%}

<div class="section--padding{% if section.settings.show_divider %} section--divider{% endif %}">
  <div class="video-section{% unless section.settings.full_width %} page-width{% endunless %}">

    <div class="title-wrapper{% if section.settings.heading == blank and section.settings.eyebrow == blank and section.settings.subheading == blank %} title-wrapper--no-heading{% endif %}{% if section.settings.full_width %} page-width{% endif %} {{ section.settings.heading_alignment }}">
     {%- if section.settings.eyebrow != blank -%}
        <p class="video-section__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <{{ section.settings.heading_tag }} class="title {{ section.settings.heading_size }}">
          {%- render 'highlight-text',
            hl_input: section.settings.heading,
            hl_style: section.settings.highlight_style,
            hl_enable: section.settings.enable_highlight,
            hl_animateWrap: true -%}
        </{{ section.settings.heading_tag }}>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <div class="video-section__subheading rte">
          {{ section.settings.subheading }}
        </div>
      {%- endif -%}
    </div>

    <div class="video-section__frame-wrap{% if section.settings.video_width_mode == 'custom' %} video-section__frame-wrap--custom{% endif %}">
      <div class="video-section__frame">
        <noscript>
          <div class="video-section__media"
            {% if poster != null %}
              style="--ratio-percent: {{ 1 | divided_by: poster.aspect_ratio | times: 100 }}%;"
            {% endif %}
          >
            {%- if section.settings.video == null and section.settings.video_url != null -%}
              <a
                href="{{ section.settings.video_url }}"
                class="video-section__poster media media--transparent{% if poster == null %} video-section__placeholder{% endif %}"
              >
                {%- if poster != null -%}
                  {{ poster
                    | image_url: width: 3840
                    | image_tag: loading: 'lazy', sizes: sizes, widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840', alt: alt
                  }}
                {%- else -%}
                  {{ 'hero-apparel-3' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
                {%- endif -%}
              </a>
            {%- else -%}
              {{ section.settings.video
                | video_tag:
                  image_size: "1100x",
                  loop: section.settings.enable_video_looping,
                  controls: true,
                  muted: false
              }}
            {%- endif -%}
          </div>
        </noscript>

        <deferred-media class="video-section__media deferred-media no-js-hidden media-wrapper media-wrapper--large{% if fix_ratio %} media-fit-cover{% endif %}"
          data-media-id="{{ video_id }}"
          {% if poster != null %}
            style="--ratio-percent: {{ 1 | divided_by: poster.aspect_ratio | times: 100 }}%;"
          {% endif %}
        >
          <button
            id="Deferred-Poster-Modal-{{ video_id }}"
            class="video-section__poster media deferred-media__poster media--landscape"
            type="button"
          >
            {%- if poster != null -%}
              {{ poster
                | image_url: width: 3840
                | image_tag: loading: 'lazy', sizes: sizes, widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840', alt: alt
              }}
            {%- else -%}
              {{ 'hero-apparel-3' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
            {%- endif -%}
            <span class="deferred-media__poster-button motion-reduce">
              {%- render 'icon', icon: 'play' -%}
            </span>
          </button>

          <template>
            {%- if section.settings.video == null and section.settings.video_url != null -%}
              <video-section
                data-init-mode="template"
                data-parent="deferred-media"
                data-loop="{% if section.settings.enable_video_looping %}1{% else %}0{% endif %}"
                data-type="{{ section.settings.video_url.type }}"
                data-video-id="{{ section.settings.video_url.id }}"></video-section>
            {%- else -%}
              {{ section.settings.video | video_tag:
                  image_size: "1100x",
                  autoplay: true,
                  loop: section.settings.enable_video_looping,
                  controls: true,
                  muted: false
              }}
            {%- endif -%}
          </template>
        </deferred-media>
      </div>
    </div>

    {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
      <div class="video-section__cta">
        <a href="{{ section.settings.cta_link }}">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "t:sections.video.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_video_looping",
      "label": "t:sections.tab-collage.blocks.video.settings.enable_video_looping.label",
      "default": false
    },

    { "type": "header", "content": "t:sections.video.settings.header__1.content" },
    { "type": "video", "id": "video", "label": "t:sections.video.settings.video.label" },

    { "type": "header", "content": "t:sections.video.settings.header__2.content" },
    { "type": "paragraph", "content": "t:sections.video.settings.paragraph.content" },
    {
      "type": "video_url",
      "id": "video_url",
      "accept": ["youtube", "vimeo"],
      "default": "https://www.youtube.com/watch?v=_9VUPq3SxOc",
      "label": "t:sections.video.settings.video_url.label",
      "info": "t:sections.video.settings.video_url.info"
    },
    { "type": "image_picker", "id": "cover_image", "label": "t:sections.video.settings.cover_image.label" },
    { "type": "text", "id": "description", "label": "t:sections.video.settings.description.label", "info": "t:sections.video.settings.description.info" },

    { "type": "checkbox", "id": "full_width", "default": false, "label": "t:sections.all.full_width.label" },
    { "type": "checkbox", "id": "show_divider", "default": false, "label": "t:sections.all.show_divider.label" },

    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow (small text)", "default": "PACKING DEMO" },
    { "type": "inline_richtext", "id": "heading", "default": "Packaging Demo", "label": "Heading" },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Description (optional)",
      "default": "<p>Watch this quick demo to learn how to safely send your precious flowers to us. For complete shipping <a href=\"#\">guide</a>, check the guidelines below.</p>"
    },

    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        { "value": "h1", "label": "h1" },
        { "value": "h2", "label": "h2" },
        { "value": "h3", "label": "h3" },
        { "value": "h4", "label": "h4" },
        { "value": "h5", "label": "h5" },
        { "value": "h6", "label": "h6" },
        { "value": "div", "label": "div" },
        { "value": "span", "label": "span" },
        { "value": "p", "label": "p" }
      ],
      "default": "h2",
      "label": "Heading tag"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#b23b5a"
    },

    { "type": "header", "content": "Video size" },
    {
      "type": "select",
      "id": "video_width_mode",
      "label": "Video width",
      "options": [
        { "value": "auto", "label": "Match container" },
        { "value": "custom", "label": "Custom max width" }
      ],
      "default": "auto"
    },
    {
      "type": "range",
      "id": "video_max_width",
      "label": "Max width (px)",
      "min": 320,
      "max": 1600,
      "step": 20,
      "default": 1120
    },

    { "type": "header", "content": "Frame" },
    { "type": "color", "id": "frame_color", "label": "Frame color", "default": "#b23b5a" },
    { "type": "range", "id": "frame_thickness", "label": "Frame thickness (px)", "min": 0, "max": 30, "step": 1, "default": 12 },
    { "type": "range", "id": "frame_padding", "label": "Inner padding (px)", "min": 0, "max": 20, "step": 1, "default": 8 },
    { "type": "range", "id": "frame_radius", "label": "Corner radius (px)", "min": 0, "max": 30, "step": 2, "default": 0 },
    { "type": "checkbox", "id": "frame_shadow", "label": "Enable shadow", "default": true },

    /* NEW: CTA button settings */
    { "type": "header", "content": "Button (below video)" },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Download the shipping checklist" },
    { "type": "url", "id": "cta_link", "label": "Button link" },
    { "type": "color", "id": "cta_bg", "label": "Button background", "default": "#b23b5a" },
    { "type": "color", "id": "cta_text", "label": "Button text", "default": "#ffffff" },
    { "type": "range", "id": "cta_radius", "label": "Button radius (px)", "min": 0, "max": 50, "step": 2, "default": 0 },
    { "type": "range", "id": "cta_padding_y", "label": "Button padding Y (px)", "min": 8, "max": 24, "step": 1, "default": 12 },
    { "type": "range", "id": "cta_padding_x", "label": "Button padding X (px)", "min": 16, "max": 60, "step": 2, "default": 28 },

    { "type": "header", "content": "t:sections.all.colors.header.content" },
    { "type": "color", "id": "colors_highlight", "label": "t:sections.all.colors.colors_highlight.label", "default": "#ffb503" },

    { "type": "header", "content": "t:sections.all.padding.header.content" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 36 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 36 },

    { "type": "header", "content": "t:sections.all.highlight.header.content" },
    { "type": "checkbox", "id": "enable_highlight", "label": "t:sections.all.highlight.enable.label", "default": false },
    {
      "type": "select",
      "id": "highlight_style",
      "options": [
        { "value": "marker", "label": "Marker" },
        { "value": "circle", "label": "Circle" },
        { "value": "underline", "label": "Underline" },
        { "value": "bold-underline", "label": "Bold underline" },
        { "value": "modern-underline", "label": "Modern underline" },
        { "value": "sketch-underline", "label": "Sketch underline" },
        { "value": "squiggle", "label": "Squiggle" },
        { "value": "heavy-squiggle", "label": "Heavy squiggle" },
        { "value": "solid-color", "label": "Solid color" }
      ],
      "default": "marker",
      "label": "Highlight style"
    }
  ],
  "presets": [
    { "name": "t:sections.video.presets.name" }
  ],
  "disabled_on": {
    "groups": ["header", "footer", "custom.overlay"]
  }
}
{% endschema %}
