{%- style -%}
  #shopify-section-{{ section.id }} {
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;

    --content-bg: {{ section.settings.content_bg_color }};
    --content-overlay: {{ section.settings.content_overlay_opacity | divided_by: 100.0 }};

    --bar-bg: {{ section.settings.bar_bg_color }};
    --bar-text: {{ section.settings.bar_text_color }};
    --bar-gap: {{ section.settings.bar_gap }}px;
  }

  #shopify-section-{{ section.id }} .section--padding {
    padding-top: var(--pt);
    padding-bottom: var(--pb);
  }
{%- endstyle -%}

<style>
  /* Full-bleed helpers (no side gaps) */
  #shopify-section-{{ section.id }} {
    overflow-x: clip;
  }

  #shopify-section-{{ section.id }} .section--padding{
    padding-left: 0 !important;
    padding-right: 0 !important;
  }

  #shopify-section-{{ section.id }} .split-hero--full{
    width: 100vw;
    margin-left: calc(50% - 50vw);
  }


  #shopify-section-{{ section.id }} .split-hero {
    position: relative;
  }

  /* 50/50 layout */
  #shopify-section-{{ section.id }} .split-hero__grid {
    display: grid;
    grid-template-columns: 1fr 1fr; /* 50/50 */
    gap: 0;
    align-items: stretch;
    width: 100%;
    overflow: hidden;
    border-radius: {{ section.settings.radius }}px;
  }

  /* Optional reverse layout (actually swaps sides) */
  #shopify-section-{{ section.id }} .split-hero__grid.is-reversed .split-hero__media { order: 2; }
  #shopify-section-{{ section.id }} .split-hero__grid.is-reversed .split-hero__content { order: 1; }

  #shopify-section-{{ section.id }} .split-hero__media {
    position: relative;
    height: {{ section.settings.min_height_desktop }}px; /* fixed */
    background: #f4f4f4;
  }

  #shopify-section-{{ section.id }} .split-hero__media .split-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

#shopify-section-{{ section.id }} .split-hero__content {
  position: relative;
  height: {{ section.settings.min_height_desktop }}px;
  display: flex;
  align-items: center;

  padding: clamp(22px, 3vw, 44px);
  padding-left: clamp(44px, 5vw, 96px);

  background: var(--content-bg);
  overflow: hidden;
}



  /* Right panel background IMAGE (with adjustable opacity) */
  #shopify-section-{{ section.id }} .split-hero__content-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: var(--content-overlay);
  }

  #shopify-section-{{ section.id }} .split-hero__content-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .split-hero__content-inner {
    position: relative;
    z-index: 1;
    max-width: 520px;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .split-hero__eyebrow {
    margin: 0 0 12px;
    font-size: 12px;
    letter-spacing: .22em;
    text-transform: uppercase;
    opacity: .75;
  }

  #shopify-section-{{ section.id }} .split-hero__heading {
    margin: 0 0 10px;
    line-height: 1.05;
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .split-hero__text {
    margin-top: 8px;
    opacity: .9;
  }

  #shopify-section-{{ section.id }} .split-hero__text p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .split-hero__cta {
    margin-top: 18px;
    display: inline-flex;
    gap: 10px;
    align-items: center;
  }

  /* Button styling fallback */
  #shopify-section-{{ section.id }} .split-hero__btn {
    display: inline-block;
    padding: 12px 22px;
    border-radius: 2px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: .16em;
    font-size: 12px;
    font-weight: 700;
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text }};
  }
  #shopify-section-{{ section.id }} .split-hero__btn:hover {
    filter: brightness(.96);
  }

  /* Benefit bar (full width) */
  #shopify-section-{{ section.id }} .split-hero__bar {
    background: var(--bar-bg);
    color: var(--bar-text);
    margin-top: 0;
  }

  #shopify-section-{{ section.id }} .split-hero__bar-inner {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--bar-gap);
    padding: 12px clamp(12px, 3vw, 48px);
    align-items: center;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .split-hero__bar-item {
    font-size: 12px;
    letter-spacing: .04em;
    text-transform: uppercase;
    font-weight: 700;
    line-height: 1.2;
  }

  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .split-hero__grid {
      grid-template-columns: 1fr;
    }

    #shopify-section-{{ section.id }} .split-hero__media,
    #shopify-section-{{ section.id }} .split-hero__content {
      height: {{ section.settings.min_height_mobile }}px; /* fixed */
    }


    #shopify-section-{{ section.id }} .split-hero__bar-inner {
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }
  }

  @media (max-width: 520px) {
    #shopify-section-{{ section.id }} .split-hero__bar-inner {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="section--padding{% if section.settings.show_divider %} section--divider{% endif %}">
  <div class="split-hero split-hero--full">
    <div class="split-hero__grid{% if section.settings.reverse_layout %} is-reversed{% endif %}">
      {%- comment -%} Left image {%- endcomment -%}
      <div class="split-hero__media">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image
            | image_url: width: 2000
            | image_tag:
              loading: 'lazy',
              class: 'split-hero__img',
              widths: '600, 900, 1200, 1600, 2000',
              sizes: '(min-width: 990px) 50vw, 100vw'
          }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg split-hero__img' }}
        {%- endif -%}
      </div>

      {%- comment -%} Right panel {%- endcomment -%}
      <div class="split-hero__content">
        {%- if section.settings.content_bg_image != blank -%}
          <div class="split-hero__content-bg">
            {{ section.settings.content_bg_image
              | image_url: width: 2000
              | image_tag: loading: 'lazy'
            }}
          </div>
        {%- endif -%}

        <div class="split-hero__content-inner">
          {%- if section.settings.eyebrow != blank -%}
            <p class="split-hero__eyebrow">{{ section.settings.eyebrow }}</p>
          {%- endif -%}

          <{{ section.settings.heading_tag }} class="split-hero__heading {{ section.settings.heading_size }}">
            {{ section.settings.heading }}
          </{{ section.settings.heading_tag }}>

          {%- if section.settings.text != blank -%}
            <div class="split-hero__text rte">
              {{ section.settings.text }}
            </div>
          {%- endif -%}

          {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
            <div class="split-hero__cta">
              {%- if section.settings.use_theme_button -%}
                <a class="button button--primary" href="{{ section.settings.button_link }}">
                  {{ section.settings.button_label }}
                </a>
              {%- else -%}
                <a class="split-hero__btn" href="{{ section.settings.button_link }}">
                  {{ section.settings.button_label }}
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>

    {%- if section.settings.show_bar and section.blocks.size > 0 -%}
      <div class="split-hero__bar">
        <div class="split-hero__bar-inner">
          {%- for block in section.blocks -%}
            <div class="split-hero__bar-item" {{ block.shopify_attributes }}>
              {{ block.settings.label }}
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Split hero + benefit bar",
  "tag": "section",
  "class": "section",
  "max_blocks": 4,
  "settings": [
    { "type": "checkbox", "id": "show_divider", "default": false, "label": "Show divider" },

    { "type": "image_picker", "id": "image", "label": "Left image" },

    { "type": "checkbox", "id": "reverse_layout", "default": false, "label": "Reverse layout (text left, image right)" },

    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "SAVE THE MOMENTS YOU SHOULD NEVER FORGET" },

    { "type": "text", "id": "heading", "label": "Heading", "default": "Don’t Let Your Special Day Become A Memory" },

    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>You only get one bouquet. One day. One chance to keep it and share with generations to come. Most brides wish they booked sooner. You'll be glad you did.</p>"
    },

    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "options": [
        { "value": "h1", "label": "h1" },
        { "value": "h2", "label": "h2" },
        { "value": "h3", "label": "h3" },
        { "value": "div", "label": "div" }
      ],
      "default": "h2"
    },

    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size class (optional)",
      "options": [
        { "value": "", "label": "None" },
        { "value": "h0", "label": "h0" },
        { "value": "h1", "label": "h1" },
        { "value": "h2", "label": "h2" }
      ],
      "default": ""
    },

    { "type": "header", "content": "Right panel background" },
    { "type": "color", "id": "content_bg_color", "label": "Content background color", "default": "#ffffff" },
    { "type": "image_picker", "id": "content_bg_image", "label": "Content background image (optional)" },
    { "type": "range", "id": "content_overlay_opacity", "label": "Background image opacity (%)", "min": 0, "max": 100, "step": 5, "default": 30 },

    { "type": "header", "content": "Button" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "PRESERVE MY BOUQUET" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "checkbox", "id": "use_theme_button", "label": "Use theme button classes (button button--primary)", "default": true },
    { "type": "color", "id": "button_bg", "label": "Button background (if not using theme button)", "default": "#b23b5a" },
    { "type": "color", "id": "button_text", "label": "Button text (if not using theme button)", "default": "#ffffff" },

    { "type": "header", "content": "Benefit bar" },
    { "type": "checkbox", "id": "show_bar", "label": "Show benefit bar", "default": true },
    { "type": "color", "id": "bar_bg_color", "label": "Bar background", "default": "#b23b5a" },
    { "type": "color", "id": "bar_text_color", "label": "Bar text", "default": "#ffffff" },
    { "type": "range", "id": "bar_gap", "label": "Bar item gap (px)", "min": 0, "max": 40, "step": 2, "default": 16 },

    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "radius", "label": "Corner radius (px)", "min": 0, "max": 30, "step": 2, "default": 0 },
    { "type": "range", "id": "min_height_desktop", "label": "Min height desktop (px)", "min": 320, "max": 760, "step": 20, "default": 520 },
    { "type": "range", "id": "min_height_mobile", "label": "Min height mobile (px)", "min": 220, "max": 600, "step": 20, "default": 360 },

    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 0 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 0 }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "text", "id": "label", "label": "Text", "default": "WOMAN OWNED AND OPERATED" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Split hero + benefit bar",
      "blocks": [
        { "type": "benefit" },
        { "type": "benefit", "settings": { "label": "TRUSTED BY TOP FLORISTS IN NEW YORK" } },
        { "type": "benefit", "settings": { "label": "LIMITED SPOTS EACH MONTH" } },
        { "type": "benefit", "settings": { "label": "VIP COMMUNICATION & CUSTOM SERVICE" } }
      ]
    }
  ],
  "disabled_on": { "groups": ["header", "footer", "custom.overlay"] }
}
{% endschema %}
