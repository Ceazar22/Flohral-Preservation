<script>
  (function(){
    var section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;

    var root = section.querySelector('[data-cbgstatic-root]');
    if (!root) return;

    var modal = section.querySelector('#cbgStatic-modal-{{ section.id }}');
    var lastFocus = null;

    function cssEscape(value) {
      if (window.CSS && CSS.escape) return CSS.escape(value);
      return String(value).replace(/[^a-zA-Z0-9_-]/g, '\\$&');
    }

    function isMobileView() {
      return window.matchMedia('(max-width: 600px)').matches;
    }

    function getPreferredVideoSource(tpl) {
      var mobileSource = tpl.content.querySelector('.cbgStatic-modal-source--mobile');
      var desktopSource = tpl.content.querySelector('.cbgStatic-modal-source--desktop');

      if (isMobileView() && mobileSource && mobileSource.innerHTML.trim() !== '') {
        return { html: mobileSource.innerHTML, mobile: true };
      }

      if (desktopSource && desktopSource.innerHTML.trim() !== '') {
        return { html: desktopSource.innerHTML, mobile: false };
      }

      if (mobileSource && mobileSource.innerHTML.trim() !== '') {
        return { html: mobileSource.innerHTML, mobile: true };
      }

      return { html: '', mobile: false };
    }

    function openVideoModal() {
      if (!modal) return;

      var tpl = section.querySelector('#cbgStatic-video-template-{{ section.id }}');
      var body = modal.querySelector('[data-cbgstatic-modal-body]');
      var panel = modal.querySelector('.cbgStatic-modal__panel');
      if (!tpl || !body || !panel) return;

      lastFocus = document.activeElement;
      body.innerHTML = '';

      var preferred = getPreferredVideoSource(tpl);
      body.innerHTML = preferred.html;

      if (preferred.mobile) {
        panel.classList.add('is-mobile-video');
        panel.style.setProperty('--active-mobile-ratio', tpl.getAttribute('data-mobile-ratio') || '9/16');
      } else {
        panel.classList.remove('is-mobile-video');
        panel.style.removeProperty('--active-mobile-ratio');
      }

      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      document.documentElement.style.overflow = 'hidden';

      var closeBtn = modal.querySelector('[data-cbgstatic-close]');
      if (closeBtn) closeBtn.focus();
    }

    function closeVideoModal() {
      if (!modal) return;

      var body = modal.querySelector('[data-cbgstatic-modal-body]');
      var panel = modal.querySelector('.cbgStatic-modal__panel');

      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      document.documentElement.style.overflow = '';

      if (body) body.innerHTML = '';
      if (panel) {
        panel.classList.remove('is-mobile-video');
        panel.style.removeProperty('--active-mobile-ratio');
      }

      if (lastFocus && typeof lastFocus.focus === 'function') lastFocus.focus();
    }

    function normalizeAjaxUrl(rawUrl) {
      if (!rawUrl) return null;

      try {
        var parsed = new URL(rawUrl, window.location.origin);

        return new URL(parsed.pathname + parsed.search + parsed.hash, window.location.origin);
      } catch (error) {
        console.warn('[cbgStatic] Invalid collection URL:', rawUrl);
        return null;
      }
    }

    function getUrlCompareKey(url) {
      if (!url) return '';
      try {
        var parsed = url instanceof URL ? url : normalizeAjaxUrl(url);
        if (!parsed) return '';
        parsed.searchParams.delete('page');
        return parsed.pathname + '?' + parsed.searchParams.toString();
      } catch (error) {
        return '';
      }
    }

    function findProductArea(context) {
      if (!context) return null;

      var directSelectors = [
        '#ProductGridContainer',
        '#product-grid',
        '[data-product-grid]',
        'product-grid-component',
        'collection-product-grid',
        '.product-grid-container',
        '.collection-product-grid',
        '.facets-vertical'
      ];

      for (var d = 0; d < directSelectors.length; d++) {
        var directFound = context.querySelector(directSelectors[d]);
        if (directFound && directFound !== section && !section.contains(directFound)) {
          return directFound;
        }
      }

      var productGrid = context.querySelector('.product-grid, .grid.product-grid');
      if (productGrid && productGrid !== section && !section.contains(productGrid)) {
        var gridContainer = productGrid.closest('#ProductGridContainer, .product-grid-container, .collection-product-grid, .facets-vertical');
        if (gridContainer && gridContainer !== section && !section.contains(gridContainer)) return gridContainer;
        return productGrid;
      }

      var fallbackSelectors = [
        '[id^="shopify-section-"][id*="main-collection-product-grid"]',
        '[id^="shopify-section-"][id*="collection-product-grid"]',
        '[id*="main-collection-product-grid"]',
        '[id*="collection-product-grid"]'
      ];

      for (var i = 0; i < fallbackSelectors.length; i++) {
        var found = context.querySelector(fallbackSelectors[i]);
        if (found && found !== section && !section.contains(found)) return found;
      }

      return null;
    }

    function updateActiveCardByUrl(activeUrl) {
      var activeKey = getUrlCompareKey(activeUrl || window.location.href);
      var cards = section.querySelectorAll('[data-cbgstatic-card]');

      cards.forEach(function(card){
        var cardUrl = card.getAttribute('data-cbgstatic-card-url') || '';
        var cardKey = getUrlCompareKey(cardUrl);
        card.classList.toggle('is-active', !!cardKey && cardKey === activeKey);
      });
    }

    function ajaxLoadProductsFromUrl(rawUrl, shouldPushState) {
      if (typeof shouldPushState === 'undefined') shouldPushState = true;

      var nextUrl = normalizeAjaxUrl(rawUrl);
      if (!nextUrl) return;

      var currentProductArea = findProductArea(document);

      if (!currentProductArea) {
        console.warn('[cbgStatic] Product area not found. Check your collection product grid wrapper selector. No page reload was triggered.');
        return;
      }

      root.classList.add('is-loading');

      fetch(nextUrl.toString(), {
        method: 'GET',
        credentials: 'same-origin',
        headers: {
          'X-Requested-With': 'XMLHttpRequest'
        }
      })
      .then(function(response){
        if (!response.ok) throw new Error('Request failed: ' + response.status);
        return response.text();
      })
      .then(function(html){
        var doc = new DOMParser().parseFromString(html, 'text/html');
        var nextProductArea = findProductArea(doc);

        if (!nextProductArea) {
          throw new Error('New product area not found from fetched page.');
        }

        currentProductArea.innerHTML = nextProductArea.innerHTML;

        if (shouldPushState) {
          window.history.pushState({ cbgStaticAjax: true }, '', nextUrl.toString());
        }

        updateActiveCardByUrl(nextUrl);

        document.dispatchEvent(new CustomEvent('cbgStatic:collectionUpdated', {
          bubbles: true,
          detail: {
            url: nextUrl.toString(),
            productArea: currentProductArea
          }
        }));

        document.dispatchEvent(new Event('shopify:section:load'));
      })
      .catch(function(error){
        console.error('[cbgStatic] AJAX collection update failed:', error);
      })
      .finally(function(){
        root.classList.remove('is-loading');
      });
    }

    section.addEventListener('click', function(event){
      var videoBtn = event.target.closest('[data-cbgstatic-open-video]');
      if (videoBtn) {
        event.preventDefault();
        event.stopPropagation();
        openVideoModal();
        return;
      }

      var filterBtn = event.target.closest('[data-cbgstatic-ajax-url]');
      if (filterBtn && section.contains(filterBtn)) {
        event.preventDefault();
        event.stopPropagation();
        event.stopImmediatePropagation();

        var ajaxUrl = filterBtn.getAttribute('data-cbgstatic-ajax-url') || '';
        ajaxLoadProductsFromUrl(ajaxUrl, true);
      }
    }, true);

    if (modal) {
      modal.addEventListener('click', function(event){
        if (event.target.closest('[data-cbgstatic-close]')) closeVideoModal();
      });

      document.addEventListener('keydown', function(event){
        if (!modal.classList.contains('is-open')) return;
        if (event.key === 'Escape') closeVideoModal();
      });
    }

    window.addEventListener('popstate', function(){
      ajaxLoadProductsFromUrl(window.location.href, false);
      updateActiveCardByUrl(window.location.href);
    });

    updateActiveCardByUrl(window.location.href);
  })();
</script>

