{% comment %}
  Section: Collection banner grid - Static section video + AJAX collection tiles

  What changed:
  - The hero/video area is controlled from the SECTION schema/settings, not from a block.
  - Bottom cards use the selected collection for the tile image/title and AJAX target.
  - Bottom cards are buttons, not URL links, so they do not force a full page refresh.
  - Clicking a bottom card updates the collection/product area through AJAX using the selected collection URL.
  - Same visual layout/class styling approach as the old section, but with a new class prefix to avoid conflicts.
{% endcomment %}

{%- liquid
  assign has_section_video = false
  if section.settings.hero_video != blank or section.settings.hero_video_url != blank or section.settings.hero_video_mobile != blank or section.settings.hero_video_url_mobile != blank
    assign has_section_video = true
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }}{
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
    --header-offset: {{ section.settings.header_offset }}px;

    --gap: {{ section.settings.gap }}px;

    --text-color: {{ section.settings.text_color }};
    --accent-color: {{ section.settings.accent_color }};

    --large-h: {{ section.settings.large_height }}px;
    --small-h: {{ section.settings.small_height }}px;

    --radius: {{ section.settings.radius }}px;

    --intro-bg: {{ section.settings.intro_bg }};
    --intro-pad: {{ section.settings.intro_padding }}px;
    --intro-radius: {{ section.settings.intro_radius }}px;

    --intro-pad-top-mobile: {{ section.settings.intro_padding_top_mobile }}px;
    --intro-pad-right-mobile: {{ section.settings.intro_padding_right_mobile }}px;
    --intro-pad-bottom-mobile: {{ section.settings.intro_padding_bottom_mobile }}px;
    --intro-pad-left-mobile: {{ section.settings.intro_padding_left_mobile }}px;

    --top-bg: {{ section.settings.top_row_bg }};
    --top-pad: {{ section.settings.top_row_padding }}px;
    --top-radius: {{ section.settings.top_row_radius }}px;

    --small-span: {{ section.settings.small_tile_span }};

    --intro-title-size: {{ section.settings.intro_heading_font_size }}px;
    --intro-text-size: {{ section.settings.intro_text_font_size }}px;
    --tile-label-size: {{ section.settings.tile_label_font_size }}px;
    --hero-label-size: {{ section.settings.hero_label_font_size }}px;

    --intro-title-size-mobile: {{ section.settings.intro_heading_font_size_mobile }}px;
    --intro-text-size-mobile: {{ section.settings.intro_text_font_size_mobile }}px;
    --accent-color-mobile: {{ section.settings.accent_color_mobile }};

    --hero-label-weight: {%- if section.settings.hero_label_bold -%}800{%- else -%}500{%- endif -%};
  }

  #shopify-section-{{ section.id }} .section--padding{
    padding-top: calc(var(--pt) + var(--header-offset));
    padding-bottom: var(--pb);
  }
{%- endstyle -%}

<style>
  #shopify-section-{{ section.id }}{
    overflow-x: clip;
  }

  #shopify-section-{{ section.id }} .cbgStatic{
    width: 100%;
  }

  #shopify-section-{{ section.id }} .cbgStatic-top{
    background: var(--top-bg);
    padding: var(--top-pad);
    border-radius: var(--top-radius);
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .cbgStatic-top__grid{
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: var(--gap);
    align-items: stretch;
  }

  #shopify-section-{{ section.id }} .cbgStatic-bottom{
    margin-top: var(--gap);
  }

  #shopify-section-{{ section.id }} .cbgStatic-bottom__grid{
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: var(--gap);
    align-items: stretch;
  }

  #shopify-section-{{ section.id }} .cbgStatic-intro{
    grid-column: span 4;
    min-height: var(--large-h);
    display: flex;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .cbgStatic-intro__inner{
    width: 100%;
    background: var(--intro-bg);
    padding: var(--intro-pad);
    border-radius: var(--intro-radius);
  }

  #shopify-section-{{ section.id }} .cbgStatic-intro__title{
    margin: 0 0 10px;
    color: var(--accent-color);
    font-weight: 600;
    line-height: 1.1;
    font-size: var(--intro-title-size);
  }

  #shopify-section-{{ section.id }} .cbgStatic-intro__title p{
    margin: 0;
  }

  #shopify-section-{{ section.id }} .cbgStatic-intro__text{
    margin: 0 0 18px;
    color: var(--text-color);
    line-height: 1.55;
    font-size: var(--intro-text-size);
    max-width: 34ch;
  }

  #shopify-section-{{ section.id }} .cbgStatic-intro__btn{
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }

  #shopify-section-{{ section.id }} .cbgStatic-tile{
    position: relative;
    overflow: hidden;
    border-radius: var(--radius);
    background: #f4f4f4;
  }

  #shopify-section-{{ section.id }} .cbgStatic-tile__btn,
  #shopify-section-{{ section.id }} .cbgStatic-hero__btn,
  #shopify-section-{{ section.id }} .cbgStatic-hero__static{
    display: block;
    height: 100%;
    width: 100%;
    color: inherit;
    text-decoration: none;
    background: transparent;
    border: 0;
    padding: 0;
    cursor: pointer;
    text-align: left;
    font: inherit;
  }

  #shopify-section-{{ section.id }} .cbgStatic-hero__static{
    cursor: default;
  }

  #shopify-section-{{ section.id }} .cbgStatic-tile__media{
    position: absolute;
    inset: 0;
  }

  #shopify-section-{{ section.id }} .cbgStatic-media-mobile{
    display: none;
  }

  #shopify-section-{{ section.id }} .cbgStatic-media-desktop{
    display: block;
    position: absolute;
    inset: 0;
  }

  #shopify-section-{{ section.id }} .cbgStatic-tile__media img,
  #shopify-section-{{ section.id }} .cbgStatic-tile__media svg,
  #shopify-section-{{ section.id }} .cbgStatic-tile__media video{
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .cbgStatic-tile__media iframe{
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .cbgStatic-tile::after{
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(to top, rgba(0,0,0,.40), rgba(0,0,0,0) 55%);
    opacity: .95;
  }

  #shopify-section-{{ section.id }} .cbgStatic-tile__label{
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 14px;
    z-index: 2;
    color: #fff;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    font-size: var(--tile-label-size);
    line-height: 1.15;
    text-shadow: 0 2px 10px rgba(0,0,0,.35);
  }

  #shopify-section-{{ section.id }} .cbgStatic-tile.is-hero .cbgStatic-tile__label{
    font-size: var(--hero-label-size);
    font-weight: var(--hero-label-weight);
  }

  #shopify-section-{{ section.id }} .cbgStatic-tile__play{
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .cbgStatic-tile__play span{
    width: 66px;
    height: 66px;
    border-radius: 999px;
    background: rgba(0,0,0,.45);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .cbgStatic-tile__play svg{
    width: 22px;
    height: 22px;
    fill: #fff;
    margin-left: 2px;
  }

  #shopify-section-{{ section.id }} .cbgStatic-tile.is-active{
    outline: 2px solid var(--accent-color);
    outline-offset: 3px;
  }

  @media (hover:hover){
    #shopify-section-{{ section.id }} .cbgStatic-tile__media img,
    #shopify-section-{{ section.id }} .cbgStatic-tile__media video{
      transform: scale(1);
      transition: transform .35s ease;
    }

    #shopify-section-{{ section.id }} .cbgStatic-tile:hover .cbgStatic-tile__media img,
    #shopify-section-{{ section.id }} .cbgStatic-tile:hover .cbgStatic-tile__media video{
      transform: scale(1.04);
    }
  }

  #shopify-section-{{ section.id }} .cbgStatic-tile.is-hero{
    grid-column: span 8;
    min-height: var(--large-h);
  }

  #shopify-section-{{ section.id }} .cbgStatic-tile.is-small{
    grid-column: span var(--small-span);
    min-height: var(--small-h);
  }

  #shopify-section-{{ section.id }} .cbgStatic.is-loading .cbgStatic-bottom__grid{
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .cbgStatic.is-loading .cbgStatic-tile__btn{
    cursor: wait;
  }

  @media (max-width: 989px){
    #shopify-section-{{ section.id }} .cbgStatic-top__grid,
    #shopify-section-{{ section.id }} .cbgStatic-bottom__grid{
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    #shopify-section-{{ section.id }} .cbgStatic-intro{
      grid-column: 1 / -1;
      min-height: auto;
    }

    #shopify-section-{{ section.id }} .cbgStatic-tile.is-hero,
    #shopify-section-{{ section.id }} .cbgStatic-tile.is-small{
      grid-column: span 1;
      min-height: 220px;
    }
  }

  @media (max-width: 600px){
    #shopify-section-{{ section.id }} .cbgStatic-top{
      padding: 0;
      background: transparent;
      border-radius: 0;
      overflow: visible;
    }

    #shopify-section-{{ section.id }} .cbgStatic-bottom{
      margin-top: var(--gap);
    }

    #shopify-section-{{ section.id }} .cbgStatic-top__grid,
    #shopify-section-{{ section.id }} .cbgStatic-bottom__grid{
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    #shopify-section-{{ section.id }} .cbgStatic-intro{
      display: none;
    }

    #shopify-section-{{ section.id }} .cbgStatic-tile.is-hero{
      grid-column: 1 / -1;
      min-height: auto;
      aspect-ratio: 1.55 / 1;
    }

    #shopify-section-{{ section.id }} .cbgStatic-tile.is-small{
      grid-column: span 1;
      min-height: auto;
      aspect-ratio: 1 / 1;
    }

    #shopify-section-{{ section.id }} .cbgStatic-intro__inner{
      padding-top: var(--intro-pad-top-mobile);
      padding-right: var(--intro-pad-right-mobile);
      padding-bottom: var(--intro-pad-bottom-mobile);
      padding-left: var(--intro-pad-left-mobile);
    }

    #shopify-section-{{ section.id }} .cbgStatic-intro__title{
      font-size: var(--intro-title-size-mobile);
      color: var(--accent-color-mobile);
      {% if section.settings.center_heading_mobile %}
      text-align: center;
      {% endif %}
    }

    #shopify-section-{{ section.id }} .cbgStatic-intro__text{
      font-size: var(--intro-text-size-mobile);
      {% if section.settings.center_heading_mobile %}
      text-align: center;
      margin-left: auto;
      margin-right: auto;
      {% endif %}
    }

    #shopify-section-{{ section.id }} .cbgStatic-intro__btn{
      {% if section.settings.center_heading_mobile %}
      margin-left: auto;
      margin-right: auto;
      display: flex;
      width: fit-content;
      {% endif %}
    }

    #shopify-section-{{ section.id }} .cbgStatic-media-desktop{
      display: none;
    }

    #shopify-section-{{ section.id }} .cbgStatic-media-mobile{
      display: block;
      position: absolute;
      inset: 0;
    }

    #shopify-section-{{ section.id }} .cbgStatic-tile__label{
      left: 10px;
      right: 10px;
      bottom: 10px;
      font-size: 11px;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .cbgStatic-tile.is-hero .cbgStatic-tile__label{
      font-size: 14px;
    }
  }

  #shopify-section-{{ section.id }} .cbgStatic-modal{
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
  }

  #shopify-section-{{ section.id }} .cbgStatic-modal.is-open{
    display: block;
  }

  #shopify-section-{{ section.id }} .cbgStatic-modal__backdrop{
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,.65);
  }

  #shopify-section-{{ section.id }} .cbgStatic-modal__panel{
    position: relative;
    z-index: 2;
    width: min(980px, calc(100% - 32px));
    margin: 7vh auto;
    background: #fff;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 20px 70px rgba(0,0,0,.35);
  }

  #shopify-section-{{ section.id }} .cbgStatic-modal__panel.is-mobile-video{
    width: min(420px, calc(100% - 24px));
  }

  #shopify-section-{{ section.id }} .cbgStatic-modal__topbar{
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 12px 14px;
    border-bottom: 1px solid rgba(0,0,0,.08);
  }

  #shopify-section-{{ section.id }} .cbgStatic-modal__title{
    font-weight: 800;
    font-size: 14px;
    letter-spacing: .02em;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .cbgStatic-modal__close{
    width: 38px;
    height: 38px;
    border-radius: 999px;
    border: 0;
    background: rgba(0,0,0,.06);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .cbgStatic-modal__close svg{
    width: 18px;
    height: 18px;
  }

  #shopify-section-{{ section.id }} .cbgStatic-modal__body{
    position: relative;
    background: #000;
    aspect-ratio: 16 / 9;
  }

  #shopify-section-{{ section.id }} .cbgStatic-modal__panel.is-mobile-video .cbgStatic-modal__body{
    aspect-ratio: var(--active-mobile-ratio, 9 / 16);
  }

  #shopify-section-{{ section.id }} .cbgStatic-modal__body video,
  #shopify-section-{{ section.id }} .cbgStatic-modal__body iframe{
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    border: 0;
  }
</style>

<div class="section--padding{% if section.settings.show_divider %} section--divider{% endif %}">
  <div class="{% if section.settings.full_width %}page-width--full-width{% else %}page-width{% endif %}">
    <div class="cbgStatic" data-cbgstatic-root>
      <div class="cbgStatic-top">
        <div class="cbgStatic-top__grid">
          <div class="cbgStatic-intro">
            <div class="cbgStatic-intro__inner">
              {%- if section.settings.heading != blank -%}
                <{{ section.settings.heading_tag }} class="cbgStatic-intro__title {{ section.settings.heading_size }}">
                  {{ section.settings.heading }}
                </{{ section.settings.heading_tag }}>
              {%- endif -%}

              {%- if section.settings.text != blank -%}
                <div class="cbgStatic-intro__text rte">{{ section.settings.text }}</div>
              {%- endif -%}

              {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
                <a class="button cbgStatic-intro__btn" href="{{ section.settings.button_link }}">
                  {{ section.settings.button_label | escape }}
                </a>
              {%- endif -%}
            </div>
          </div>

          <div class="cbgStatic-tile is-hero" {{ section.shopify_attributes }}>
            {%- if has_section_video -%}
              <button
                type="button"
                class="cbgStatic-hero__btn"
                data-cbgstatic-open-video
                aria-label="Play {{ section.settings.video_label | escape }}"
              >
            {%- else -%}
              <div class="cbgStatic-hero__static">
            {%- endif -%}

              <div class="cbgStatic-tile__media">
                <div class="cbgStatic-media-desktop">
                  {%- if section.settings.hero_video != blank -%}
                    {{ section.settings.hero_video
                      | video_tag:
                        autoplay: true,
                        loop: true,
                        muted: true,
                        controls: false,
                        playsinline: true
                    }}
                  {%- elsif section.settings.hero_video_url != blank -%}
                    {%- liquid
                      assign desktop_video_url = section.settings.hero_video_url
                      assign desktop_embed_url = ''
                      if desktop_video_url.type == 'youtube'
                        assign desktop_embed_url = 'https://www.youtube.com/embed/' | append: desktop_video_url.id | append: '?autoplay=1&mute=1&loop=1&playlist=' | append: desktop_video_url.id | append: '&controls=0&rel=0&playsinline=1'
                      elsif desktop_video_url.type == 'vimeo'
                        assign desktop_embed_url = 'https://player.vimeo.com/video/' | append: desktop_video_url.id | append: '?autoplay=1&muted=1&loop=1&background=1'
                      endif
                    -%}
                    {%- if desktop_embed_url != blank -%}
                      <iframe
                        src="{{ desktop_embed_url }}"
                        loading="lazy"
                        allow="autoplay; fullscreen; picture-in-picture"
                        title="{{ section.settings.video_label | escape }}"
                      ></iframe>
                    {%- elsif section.settings.hero_image != blank -%}
                      {{ section.settings.hero_image | image_url: width: 2400 | image_tag: loading: 'lazy', widths: '600, 900, 1200, 1600, 2000, 2400' }}
                    {%- else -%}
                      {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                    {%- endif -%}
                  {%- elsif section.settings.hero_image != blank -%}
                    {{ section.settings.hero_image | image_url: width: 2400 | image_tag: loading: 'lazy', widths: '600, 900, 1200, 1600, 2000, 2400' }}
                  {%- else -%}
                    {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </div>

                <div class="cbgStatic-media-mobile">
                  {%- if section.settings.hero_video_mobile != blank -%}
                    {{ section.settings.hero_video_mobile
                      | video_tag:
                        autoplay: true,
                        loop: true,
                        muted: true,
                        controls: false,
                        playsinline: true
                    }}
                  {%- elsif section.settings.hero_video_url_mobile != blank -%}
                    {%- liquid
                      assign mobile_video_url = section.settings.hero_video_url_mobile
                      assign mobile_embed_url = ''
                      if mobile_video_url.type == 'youtube'
                        assign mobile_embed_url = 'https://www.youtube.com/embed/' | append: mobile_video_url.id | append: '?autoplay=1&mute=1&loop=1&playlist=' | append: mobile_video_url.id | append: '&controls=0&rel=0&playsinline=1'
                      elsif mobile_video_url.type == 'vimeo'
                        assign mobile_embed_url = 'https://player.vimeo.com/video/' | append: mobile_video_url.id | append: '?autoplay=1&muted=1&loop=1&background=1'
                      endif
                    -%}
                    {%- if mobile_embed_url != blank -%}
                      <iframe
                        src="{{ mobile_embed_url }}"
                        loading="lazy"
                        allow="autoplay; fullscreen; picture-in-picture"
                        title="{{ section.settings.video_label | escape }}"
                      ></iframe>
                    {%- endif -%}
                  {%- elsif section.settings.hero_video != blank -%}
                    {{ section.settings.hero_video
                      | video_tag:
                        autoplay: true,
                        loop: true,
                        muted: true,
                        controls: false,
                        playsinline: true
                    }}
                  {%- elsif section.settings.hero_video_url != blank -%}
                    {%- liquid
                      assign fallback_video_url = section.settings.hero_video_url
                      assign fallback_embed_url = ''
                      if fallback_video_url.type == 'youtube'
                        assign fallback_embed_url = 'https://www.youtube.com/embed/' | append: fallback_video_url.id | append: '?autoplay=1&mute=1&loop=1&playlist=' | append: fallback_video_url.id | append: '&controls=0&rel=0&playsinline=1'
                      elsif fallback_video_url.type == 'vimeo'
                        assign fallback_embed_url = 'https://player.vimeo.com/video/' | append: fallback_video_url.id | append: '?autoplay=1&muted=1&loop=1&background=1'
                      endif
                    -%}
                    {%- if fallback_embed_url != blank -%}
                      <iframe
                        src="{{ fallback_embed_url }}"
                        loading="lazy"
                        allow="autoplay; fullscreen; picture-in-picture"
                        title="{{ section.settings.video_label | escape }}"
                      ></iframe>
                    {%- endif -%}
                  {%- elsif section.settings.hero_image_mobile != blank -%}
                    {{ section.settings.hero_image_mobile | image_url: width: 1400 | image_tag: loading: 'lazy', widths: '500, 750, 1000, 1400' }}
                  {%- elsif section.settings.hero_image != blank -%}
                    {{ section.settings.hero_image | image_url: width: 1400 | image_tag: loading: 'lazy', widths: '500, 750, 1000, 1400' }}
                  {%- else -%}
                    {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </div>
              </div>

              {%- if section.settings.video_label != blank -%}
                <div class="cbgStatic-tile__label">{{ section.settings.video_label }}</div>
              {%- endif -%}

              {%- if has_section_video and section.settings.show_play_icon -%}
                <div class="cbgStatic-tile__play" aria-hidden="true">
                  <span>
                    <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                  </span>
                </div>
              {%- endif -%}

            {%- if has_section_video -%}
              </button>
            {%- else -%}
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>

      <div class="cbgStatic-bottom">
        <div class="cbgStatic-bottom__grid">
          {%- for block in section.blocks -%}
            {%- liquid
              assign c = block.settings.collection
              assign label = block.settings.label

              if c != blank
                if label == blank or label == 'Collection'
                  assign label = c.title
                endif
              endif

              assign fallback_img = blank
              if c != blank and c.image != blank
                assign fallback_img = c.image
              elsif c != blank and c.featured_image != blank
                assign fallback_img = c.featured_image
              elsif c != blank and c.products.first.featured_image != blank
                assign fallback_img = c.products.first.featured_image
              endif

              assign ajax_collection_url = blank
              if c != blank and c.url != blank
                assign ajax_collection_url = c.url
              endif
            -%}

            <div
              class="cbgStatic-tile is-small"
              data-cbgstatic-card
              data-cbgstatic-card-url="{{ ajax_collection_url | escape }}"
              {{ block.shopify_attributes }}
            >
              <button
                type="button"
                class="cbgStatic-tile__btn"
                data-cbgstatic-ajax-url="{{ ajax_collection_url | escape }}"
                aria-label="Show {{ label | escape }} products"
                {% if ajax_collection_url == blank %}disabled{% endif %}
              >
                <div class="cbgStatic-tile__media">
                  {%- if block.settings.thumb_image != blank -%}
                    {{ block.settings.thumb_image | image_url: width: 1600 | image_tag: loading: 'lazy', widths: '400, 600, 900, 1200, 1600' }}
                  {%- elsif fallback_img != blank -%}
                    {{ fallback_img | image_url: width: 1600 | image_tag: loading: 'lazy', widths: '400, 600, 900, 1200, 1600' }}
                  {%- else -%}
                    {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </div>

                {%- if label != blank -%}
